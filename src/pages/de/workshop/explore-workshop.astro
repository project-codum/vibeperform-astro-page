---
import '../../../styles/global.css';
import ExploreWorkshopPage from '../../../components/ExploreWorkshopPage.astro';
import { exploreWorkshopContent } from '../../../data/exploreWorkshopContent';
import { absoluteUrl, jsonLd, serviceSchema } from '../../../lib/siteMetadata';

const title = 'Phase 1 Workshop | Strategic Discovery Sprint | Vibeperform';
const description =
	'Strategic Discovery Sprint: KI-Roadmap, Use-Case-Priorisierung und klare technische Voraussetzungen für den Einstieg in wirksame KI-Lösungen.';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const canonicalUrl = absoluteUrl('/de/workshop/explore-workshop');
const alternateUrl = absoluteUrl('/en/workshop/explore-workshop');
const structuredData = serviceSchema({
	name: exploreWorkshopContent.de.title,
	description,
	pathname: '/de/workshop/explore-workshop',
	locale: 'de',
	serviceType: 'Strategischer KI-Explore-Workshop',
});
---

<html lang="de">
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
		<script type="application/ld+json" set:html={jsonLd(structuredData)} />
	</head>
	<body class="bg-white text-slate-900">
		<ExploreWorkshopPage currentLocale="de" />
	</body>
</html>
