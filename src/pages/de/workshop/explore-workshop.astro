---
import '../../../styles/global.css';
import ExploreWorkshopPage from '../../../components/ExploreWorkshopPage.astro';

const title = 'Phase 1 Workshop | Strategic Discovery Sprint | Vibeperform';
const description =
	'Strategic Discovery Sprint: KI-Roadmap, Use-Case-Priorisierung und klare technische Voraussetzungen für den Einstieg in wirksame KI-Lösungen.';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
---

<html lang="de">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-white text-slate-900">
		<ExploreWorkshopPage currentLocale="de" />
	</body>
</html>
