---
import '../../styles/global.css';
import StrategyPage from '../../components/StrategyPage.astro';
import { strategyContent } from '../../data/strategyContent';
import { homeContent } from '../../data/homeContent';
import { absoluteUrl } from '../../lib/siteMetadata';

const nav = homeContent.de.nav;
const homeHref = '/de/';
const alternateLocaleHref = '/en/ai-strategy';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const description = strategyContent.de.hero.subtitle;
const canonicalUrl = absoluteUrl('/de/ki-strategie');
const alternateUrl = absoluteUrl(alternateLocaleHref);
---

<html lang="de">
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{strategyContent.de.metaTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
	</head>
	<body class="bg-white text-slate-900">
		<StrategyPage
			content={strategyContent.de}
			currentLocale="de"
			nav={nav}
			homeHref={homeHref}
			alternateLocaleHref={alternateLocaleHref}
		/>
	</body>
</html>
