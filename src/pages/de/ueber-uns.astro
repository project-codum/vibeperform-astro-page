---
import '../../styles/global.css';
import AboutPage from '../../components/AboutPage.astro';
import { aboutContent } from '../../data/aboutContent';
import { absoluteUrl } from '../../lib/siteMetadata';

const content = aboutContent.de;
const homeHref = '/de/';
const alternateLocaleHref = '/en/about-us';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const description = content.hero.intro;
const canonicalUrl = absoluteUrl('/de/ueber-uns');
const alternateUrl = absoluteUrl(alternateLocaleHref);
---

<html lang="de">
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-FQ744XXNZ7"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-FQ744XXNZ7');
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{aboutContent.de.metaTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
	</head>

	<body class="bg-white text-slate-900">
		<AboutPage
			content={content}
			homeHref={homeHref}
			alternateLocaleHref={alternateLocaleHref}
			currentLocale="de"
		/>
	</body>
</html>
