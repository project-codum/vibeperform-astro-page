---
import '../../styles/global.css';
import HomePage from '../../components/HomePage.astro';
import { homeContent } from '../../data/homeContent';
import { absoluteUrl, jsonLd, organizationSchema, websiteSchema } from '../../lib/siteMetadata';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const description = homeContent.de.hero.subtitle;
const canonicalUrl = absoluteUrl('/de/');
const alternateUrl = absoluteUrl('/en/');
const structuredData = [organizationSchema(), websiteSchema('de')];
---

<html lang="de">
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<meta name="generator" content={Astro.generator} />
		<title>Vibeperform</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
		<script type="application/ld+json" set:html={jsonLd(structuredData)} />
	</head>

	<body class="bg-white text-slate-900">
		<HomePage content={homeContent.de} currentLocale="de" alternateLocaleHref="/en/" />
	</body>
</html>
