---
import '../../styles/global.css';
import WorkshopsPage from '../../components/WorkshopsPage.astro';
import { workshopsContent } from '../../data/workshopsContent';
import { absoluteUrl, jsonLd, offerCatalogSchema } from '../../lib/siteMetadata';

const content = workshopsContent.en;
const homeHref = '/en/';
const alternateLocaleHref = '/de/workshops';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const description = content.hero.intro;
const canonicalUrl = absoluteUrl('/en/workshops');
const alternateUrl = absoluteUrl(alternateLocaleHref);
const structuredData = offerCatalogSchema({
	name: content.hero.title,
	description,
	pathname: '/en/workshops',
	locale: 'en',
	offers: content.offerings.map((offer) => ({
		name: offer.title,
		description: offer.description,
	})),
});
---

<html lang="en">
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-FQ744XXNZ7"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-FQ744XXNZ7');
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{content.metaTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={alternateUrl} />
		<script type="application/ld+json" set:html={jsonLd(structuredData)} />
	</head>

	<body class="bg-white text-slate-900">
		<WorkshopsPage
			content={content}
			homeHref={homeHref}
			alternateLocaleHref={alternateLocaleHref}
			currentLocale="en"
		/>
	</body>
</html>
