---
import '../../styles/global.css';
import LegalPage from '../../components/LegalPage.astro';
import { legalContent } from '../../data/legalContent';
import { absoluteUrl } from '../../lib/siteMetadata';

const content = legalContent.en.legalNotice;
const homeHref = '/en/';
const alternateLocaleHref = '/de/impressum';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const canonicalUrl = absoluteUrl('/en/legal-notice');
const alternateUrl = absoluteUrl(alternateLocaleHref);
---

<html lang="en">
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-FQ744XXNZ7"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-FQ744XXNZ7');
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{content.metaTitle}</title>
		<meta name="description" content={content.metaDescription} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={canonicalUrl} />
		<link rel="alternate" hreflang="de" href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={alternateUrl} />
	</head>

	<body class="bg-white text-slate-900">
		<LegalPage
			content={content}
			homeHref={homeHref}
			alternateLocaleHref={alternateLocaleHref}
			currentLocale="en"
		/>
	</body>
</html>
