---
import Button from "./Button.astro";
import Footer from "./Footer.astro";
import LandingHighlights from "./LandingHighlights.astro";
import LandingTrustSections from "./LandingTrustSections.astro";
import NavBar from "./NavBar.astro";
import RotatingHeadline from "./RotatingHeadline.astro";
import type { HomeContent } from "../data/homeContent";
import {
  FileText,
  FlaskConical,
  Layers,
  SearchCheck,
  Users,
  Workflow,
} from "lucide-static";

interface Props {
  content: HomeContent;
  currentLocale: string;
  alternateLocaleHref: string;
}

const featureIcons = {
  "search-check": SearchCheck,
  workflow: Workflow,
} as const;

const deliverablesContent = {
  en: {
    heading: "What we deliver",
    subheading: "A clear package for fast, evidence-based AI decisions.",
    cards: [
      {
        title: "Use Case Portfolio",
        description: "10–20 ideas, top 3 prioritised by value/complexity.",
        icon: Layers,
      },
      {
        title: "Decision Brief",
        description: "Business, tech, and risk lenses for every use case.",
        icon: FileText,
      },
      {
        title: "Prototype/PoC (optional)",
        description: "Working clickable or data prototype with instrumentation.",
        icon: FlaskConical,
      },
      {
        title: "Enablement",
        description:
          "Your team knows where AI drives impact and how to safeguard quality.",
        icon: Users,
      },
    ],
  },
  de: {
    heading: "Was wir liefern",
    subheading:
      "Ein klares Paket für schnelle, fundierte KI-Entscheidungen.",
    cards: [
      {
        title: "Use-Case-Portfolio",
        description: "10–20 Ideen, Top-3 priorisiert mit Nutzen/Komplexität.",
        icon: Layers,
      },
      {
        title: "Entscheidungsvorlage",
        description: "Business-, Tech- und Risiko-Sicht je Use Case.",
        icon: FileText,
      },
      {
        title: "Prototyp/PoC (optional)",
        description:
          "Funktionierender Klick- oder Daten-Prototyp mit Messpunkten.",
        icon: FlaskConical,
      },
      {
        title: "Enablement",
        description:
          "Ihr Team versteht, wo KI wirkt und wie Qualität gesichert wird.",
        icon: Users,
      },
    ],
  },
} as const;

const renderFeatureIcon = (key?: keyof typeof featureIcons | string) => {
  const iconSvg =
    key && key in featureIcons
      ? featureIcons[key as keyof typeof featureIcons]
      : featureIcons["search-check"];

  return iconSvg
    .replace('class="lucide', 'class="lucide h-10 w-10')
    .replace('width="24"', 'width="40"')
    .replace('height="24"', 'height="40"');
};

const renderDeliverableIcon = (iconSvg: string) =>
  iconSvg.replace('class="lucide', 'class="lucide h-6 w-6 text-purple-600');

const { content, currentLocale, alternateLocaleHref } = Astro.props as Props;
const { nav, hero, features } = content;
const basePath = "";
const locale = currentLocale === "de" ? "de" : "en";
const homeHref = locale === "de" ? `${basePath}/de/` : `${basePath}/`;
const deliverablesSection = deliverablesContent[locale];
const featuresSectionId = locale === "de" ? "so-arbeiten-wir" : "how-we-work";
const heroParticles = Array.from({ length: 18 }, (_, index) => index + 1);
const approachContent = {
  en: {
    heading: "Our approach (proven & lean)",
    steps: [
      {
        number: "1",
        title: "Explore Workshop",
        subheader: "Find valuable AI ideas",
        description:
          "In 1 day (or 2 half days remote) we surface challenges, generate use cases with curated cards and guides, and prioritise together.",
      },
      {
        number: "2",
        title: "Design Workshop",
        subheader: "Define the to-be scenario",
        description:
          "We deepen 1–3 shortlisted use cases and shape the target state that can actually be delivered.",
      },
      {
        number: "3",
        title: "Market & Tool Scan",
        subheader: "Decide build or buy",
        description:
          "If battle-tested solutions already exist that solve your challenge faster or at lower cost, we recommend them transparently. If nothing fits, we co-design a tailored AI or automation solution.",
      },
      {
        number: "4",
        title: "Build Sprint (2–4 weeks)",
        subheader: "Proof over PowerPoint",
        description:
          "In 2–4 weeks we co-develop a first testable prototype. Afterwards we decide on deployment together and support change and rollout so the solution lands in everyday work.",
      },
    ],
  },
  de: {
    heading: "Unser Vorgehen (bewährt & schlank)",
    steps: [
      {
        number: "1",
        title: "Explore Workshop",
        subheader: "Wertvolle KI-Ideen finden",
        description:
          "In 1 Tag (oder 2×½ Tage remote) identifizieren wir Herausforderungen, generieren Use Cases mit Karten/Leitfäden und priorisieren gemeinsam.",
      },
      {
        number: "2",
        title: "Design Workshop",
        subheader: "To-Be-Szenario definieren",
        description:
          "Wir vertiefen 1–3 Favoriten Use Cases und definieren den umsetzbaren Zielzustand.",
      },
      {
        number: "3",
        title: "Markt- & Tool-Scan",
        subheader: "Build-or-Buy entscheiden",
        description:
          "Wenn es bereits erprobte Lösungen gibt, die eure Herausforderung schneller oder günstiger lösen, empfehlen wir diese offen weiter. Wenn keine passende Lösung existiert, entwickeln wir gemeinsam eine maßgeschneiderte KI- oder Automatisierungslösung.",
      },
      {
        number: "4",
        title: "Build Sprint (2–4 Wochen)",
        subheader: "Schneller Proof statt PowerPoint",
        description:
          "In 2–4 Wochen entwickeln wir gemeinsam einen ersten testbaren Prototypen. Danach treffen wir die Einführungsentscheidung und begleiten Weiterentwicklung, Change & Rollout, damit die Lösung im Alltag angenommen wird.",
      },
    ],
  },
} as const;
const approachSection = approachContent[locale];
---

<div class="flex min-h-screen flex-col bg-white">
  <NavBar
    nav={nav}
    homeHref={homeHref}
    alternateLocaleHref={alternateLocaleHref}
  />
  <main class="flex flex-1 flex-col pb-20">
    <section id="about-us" class="spark-hero section-spacing">
      <div class="spark-hero__backdrop" aria-hidden="true">
        <div class="spark-hero__grid"></div>
        <div class="spark-hero__glow spark-hero__glow--violet"></div>
        <div class="spark-hero__glow spark-hero__glow--cyan"></div>
        <div class="spark-hero__glow spark-hero__glow--emerald"></div>
        <div class="spark-hero__particles">
          {heroParticles.map((particle) => <span style={`--i: ${particle}`} />)}
        </div>
        <span class="spark-hero__shape spark-hero__shape--one"></span>
        <span class="spark-hero__shape spark-hero__shape--two"></span>
        <span class="spark-hero__shape spark-hero__shape--three"></span>
      </div>

      <div class="spark-hero__inner container-responsive">
        <div class="spark-hero__copy">
          <p class="spark-hero__kicker">
            {hero.kicker}
          </p>

          <h1 class="spark-hero__title">
            <RotatingHeadline words={hero.rotatingWords} />
          </h1>

          <p class="spark-hero__subtitle">{hero.subtitle}</p>

          <div class="flex w-full flex-col items-center gap-3 pt-4 sm:flex-row lg:items-start">
            <Button href={hero.primaryHref}>{hero.primaryCta}</Button>
            {hero.secondaryHref && hero.secondaryCta ? (
              <a
                class="inline-flex min-h-[2.75rem] w-full items-center justify-center rounded-full border border-white/20 bg-white/5 px-4 text-sm font-semibold text-slate-100 shadow-[0_0_26px_rgba(168,85,247,0.18)] backdrop-blur transition hover:border-cyan-300/50 hover:bg-white/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-cyan-300 sm:w-auto"
                href={hero.secondaryHref}
              >
                {hero.secondaryCta}
              </a>
            ) : null}
          </div>
        </div>

        <div class="spark-hero__visual" aria-hidden="true">
          <div class="spark-orbit spark-orbit--outer"></div>
          <div class="spark-orbit spark-orbit--middle"></div>
          <div class="spark-orbit spark-orbit--inner"></div>
          <div class="spark-core">
            <svg class="spark-core__icon" viewBox="0 0 160 160" role="img">
              <path
                d="M80 8C85 51 109 75 152 80C109 85 85 109 80 152C75 109 51 85 8 80C51 75 75 51 80 8Z"
                fill="currentColor"
              />
              <circle cx="80" cy="8" r="8" fill="currentColor" />
              <circle cx="80" cy="152" r="7" fill="currentColor" />
              <circle cx="8" cy="80" r="6" fill="currentColor" />
            </svg>
          </div>
          <span class="spark-node spark-node--one"></span>
          <span class="spark-node spark-node--two"></span>
          <span class="spark-node spark-node--three"></span>
        </div>
      </div>
    </section>
    <section class="section-spacing bg-slate-50">
      <div class="container-responsive space-y-10">
        <div class="mx-auto max-w-3xl space-y-3 text-center">
          <h2 class="text-3xl font-semibold text-slate-900 sm:text-4xl">
            {deliverablesSection.heading}
          </h2>
          <p class="text-base text-slate-600 sm:text-lg md:text-xl">
            {deliverablesSection.subheading}
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
          {deliverablesSection.cards.map((item) => (
            <article class="flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-6 text-left shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
              <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-purple-100 text-purple-600">
                <span class="sr-only">{`${item.title} Icon`}</span>
                <div aria-hidden="true" set:html={renderDeliverableIcon(item.icon)} />
              </div>
              <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">
                {item.description}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>
    <section id={featuresSectionId} class="section-spacing bg-white">
      <div class="container-responsive space-y-10">
        <div class="space-y-4 text-center md:text-left">
          <p
            class="text-xs font-semibold uppercase tracking-[0.35em] text-slate-500"
          >
            {features.kicker ?? "Our Approach"}
          </p>
          <h2 class="text-3xl font-semibold text-slate-900 sm:text-4xl">
            {features.heading}
          </h2>
          {
            features.subheading ? (
              <p class="max-w-2xl [text-wrap:balance] text-sm text-slate-600 sm:text-base">
                {features.subheading}
              </p>
            ) : null
          }
        </div>
        <div class="space-y-6 text-left md:max-w-4xl md:max-h-[420px] md:overflow-y-auto md:pr-4 md:scroll-smooth">
          {approachSection.steps.map((step) => (
            <article class="flex flex-col gap-4 pb-6 last:pb-0 sm:flex-row sm:items-start sm:gap-6">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-purple-100 text-lg font-semibold text-purple-600">
                {step.number}
              </span>
              <div class="flex-1 space-y-3">
                <h3 class="text-xl font-semibold text-slate-900">{step.title}</h3>
                <p class="text-base font-semibold text-purple-600">
                  {step.subheader}
                </p>
                <p class="text-sm leading-relaxed text-slate-600">{step.description}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="grid-responsive md:grid-cols-2">
          {
            features.items.map((item) => (
              <article
                class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg sm:p-8"
                key={item.title}
              >
                <div
                  class="mb-4 flex justify-center text-slate-500"
                  aria-hidden="true"
                  set:html={renderFeatureIcon(item.icon)}
                />
                <h3 class="text-lg font-semibold text-slate-900 sm:text-xl">
                  {item.title}
                </h3>
                {
                  item.blocks?.map((block, blockIndex) => {
                    if (block.type === "lead") {
                      return (
                        <p
                          class="mt-4 text-sm text-slate-600 sm:text-base"
                          key={`${item.title}-block-${blockIndex}`}
                          set:html={block.html}
                        />
                      );
                    }

                    if (block.type === "paragraph") {
                      return (
                        <p
                          class="mt-3 text-sm text-slate-600 sm:text-base"
                          key={`${item.title}-block-${blockIndex}`}
                          set:html={block.html}
                        />
                      );
                    }

                    if (block.type === "heading") {
                      return (
                        <p
                          class="mt-6 text-sm font-semibold text-slate-900 sm:text-base"
                          key={`${item.title}-block-${blockIndex}`}
                          set:html={block.html}
                        />
                      );
                    }

                    if (block.type === "list") {
                      return (
                        <ul
                          class="mt-3 space-y-2 text-sm text-slate-600 sm:text-base"
                          key={`${item.title}-block-${blockIndex}`}
                        >
                          {block.items.map((entry, entryIndex) => (
                            <li class="flex gap-2" key={`${item.title}-block-${blockIndex}-entry-${entryIndex}`}>
                              <span class="text-slate-400">•</span>
                              <span class="flex-1" set:html={entry} />
                            </li>
                          ))}
                        </ul>
                      );
                    }

                    return null;
                  })
                }
              </article>
            ))
          }
        </div>
        {
          features.cta ? (
            <div class="mx-auto max-w-3xl space-y-6 rounded-3xl bg-white p-8 text-center shadow-sm sm:p-10">
              <h3 class="text-2xl font-semibold text-slate-900 sm:text-3xl">
                {features.cta.heading}
              </h3>
              <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
                <a
                  class="inline-flex items-center justify-center rounded-full bg-purple-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-purple-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple-400 sm:text-base"
                  href={features.cta.primary.href}
                >
                  {features.cta.primary.label}
                </a>
                <a
                  class="inline-flex items-center justify-center rounded-full border border-slate-200 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-900 sm:text-base"
                  href={features.cta.secondary.href}
                >
                  {features.cta.secondary.label}
                </a>
              </div>
            </div>
          ) : null
        }
      </div>
    </section>
	<LandingHighlights locale={locale} />
    <LandingTrustSections locale={locale} />
  </main>
  <Footer currentLocale={locale} />
</div>

<style>
  .spark-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(42rem, 78vh, 54rem);
    margin-inline: calc(clamp(1.5rem, 5vw, 3rem) * -1);
    color: white;
    background:
      radial-gradient(circle at 80% 18%, rgba(34, 211, 238, 0.34), transparent 28rem),
      radial-gradient(circle at 18% 22%, rgba(168, 85, 247, 0.32), transparent 30rem),
      linear-gradient(135deg, #050816 0%, #0d1228 38%, #111827 68%, #15102a 100%);
  }

  .spark-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(115deg, rgba(124, 58, 237, 0.18), transparent 35%, rgba(6, 182, 212, 0.2) 70%, transparent),
      linear-gradient(220deg, rgba(15, 23, 42, 0), rgba(88, 28, 135, 0.28), rgba(8, 47, 73, 0.14));
    background-size: 180% 180%;
    animation: hero-gradient-shift 16s ease-in-out infinite alternate;
  }

  .spark-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(0deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 4.5rem 4.5rem;
    mask-image: radial-gradient(circle at 68% 44%, black, transparent 72%);
    opacity: 0.55;
  }

  .spark-hero__backdrop {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
  }

  .spark-hero__grid {
    position: absolute;
    inset: auto -10% -28% -10%;
    height: 55%;
    background:
      linear-gradient(rgba(34, 211, 238, 0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(168, 85, 247, 0.18) 1px, transparent 1px);
    background-size: 4rem 4rem;
    transform: perspective(42rem) rotateX(66deg);
    transform-origin: top center;
    opacity: 0.48;
  }

  .spark-hero__glow {
    position: absolute;
    width: 28rem;
    height: 28rem;
    border-radius: 9999px;
    filter: blur(4rem);
    opacity: 0.52;
  }

  .spark-hero__glow--violet {
    top: 8%;
    left: 4%;
    background: rgba(147, 51, 234, 0.66);
  }

  .spark-hero__glow--cyan {
    top: 4%;
    right: 12%;
    background: rgba(6, 182, 212, 0.52);
  }

  .spark-hero__glow--emerald {
    right: 24%;
    bottom: -18%;
    background: rgba(16, 185, 129, 0.24);
  }

  .spark-hero__particles span {
    position: absolute;
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 9999px;
    background: rgba(226, 232, 240, 0.82);
    box-shadow: 0 0 18px rgba(34, 211, 238, 0.82);
    animation: particle-drift 9s linear infinite;
    animation-delay: calc(var(--i) * -0.65s);
  }

  .spark-hero__particles span:nth-child(1) { left: 8%; top: 16%; }
  .spark-hero__particles span:nth-child(2) { left: 18%; top: 72%; }
  .spark-hero__particles span:nth-child(3) { left: 27%; top: 28%; }
  .spark-hero__particles span:nth-child(4) { left: 36%; top: 82%; }
  .spark-hero__particles span:nth-child(5) { left: 44%; top: 12%; }
  .spark-hero__particles span:nth-child(6) { left: 52%; top: 62%; }
  .spark-hero__particles span:nth-child(7) { left: 62%; top: 22%; }
  .spark-hero__particles span:nth-child(8) { left: 72%; top: 76%; }
  .spark-hero__particles span:nth-child(9) { left: 84%; top: 18%; }
  .spark-hero__particles span:nth-child(10) { left: 91%; top: 52%; }
  .spark-hero__particles span:nth-child(11) { left: 13%; top: 48%; }
  .spark-hero__particles span:nth-child(12) { left: 31%; top: 56%; }
  .spark-hero__particles span:nth-child(13) { left: 47%; top: 38%; }
  .spark-hero__particles span:nth-child(14) { left: 57%; top: 86%; }
  .spark-hero__particles span:nth-child(15) { left: 67%; top: 44%; }
  .spark-hero__particles span:nth-child(16) { left: 78%; top: 32%; }
  .spark-hero__particles span:nth-child(17) { left: 88%; top: 83%; }
  .spark-hero__particles span:nth-child(18) { left: 95%; top: 25%; }

  .spark-hero__shape {
    position: absolute;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.02));
    box-shadow: inset 0 0 28px rgba(255, 255, 255, 0.06), 0 0 40px rgba(34, 211, 238, 0.14);
    backdrop-filter: blur(10px);
    animation: shape-float 10s ease-in-out infinite;
  }

  .spark-hero__shape--one {
    top: 16%;
    right: 8%;
    width: 4rem;
    height: 4rem;
    transform: rotate(18deg);
  }

  .spark-hero__shape--two {
    bottom: 18%;
    left: 7%;
    width: 5.5rem;
    height: 2.6rem;
    border-radius: 9999px;
    animation-delay: -3s;
  }

  .spark-hero__shape--three {
    right: 34%;
    bottom: 9%;
    width: 3rem;
    height: 3rem;
    clip-path: polygon(50% 0, 100% 100%, 0 100%);
    animation-delay: -6s;
  }

  .spark-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: inherit;
    grid-template-columns: minmax(0, 1.15fr) minmax(19rem, 0.85fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 4.5rem);
  }

  .spark-hero__copy {
    position: relative;
    z-index: 2;
    width: 100%;
    min-width: 0;
    max-width: 50rem;
    text-align: left;
  }

  .spark-hero__kicker {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgb(125 211 252);
    text-shadow: 0 0 24px rgba(34, 211, 238, 0.45);
  }

  .spark-hero__title {
    margin-top: 1rem;
    font-size: 2.35rem;
    font-weight: 700;
    line-height: 0.95;
    color: white;
    text-wrap: balance;
    text-shadow:
      0 0 26px rgba(168, 85, 247, 0.4),
      0 0 56px rgba(34, 211, 238, 0.22);
  }

  .spark-hero__subtitle {
    margin-top: 1.4rem;
    max-width: 35rem;
    font-size: clamp(1.05rem, 2vw, 1.32rem);
    line-height: 1.65;
    color: rgb(203 213 225);
  }

  :global(.spark-hero .rotating-headline) {
    text-align: left;
  }

  .spark-hero__visual {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    min-height: clamp(22rem, 42vw, 36rem);
    transform: translateX(clamp(3rem, 7vw, 7rem));
  }

  .spark-hero__visual::before {
    content: "";
    position: absolute;
    width: min(32rem, 80vw);
    height: min(32rem, 80vw);
    border-radius: 9999px;
    background:
      radial-gradient(circle, rgba(255, 255, 255, 0.1), transparent 38%),
      conic-gradient(from 180deg, rgba(34, 211, 238, 0.24), rgba(168, 85, 247, 0.28), rgba(16, 185, 129, 0.16), rgba(34, 211, 238, 0.24));
    filter: blur(2px);
    opacity: 0.72;
    animation: aura-breathe 5s ease-in-out infinite;
  }

  .spark-orbit {
    position: absolute;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow:
      inset 0 0 30px rgba(34, 211, 238, 0.08),
      0 0 32px rgba(168, 85, 247, 0.16);
  }

  .spark-orbit::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    border-top: 2px solid rgba(34, 211, 238, 0.92);
    border-right: 2px solid rgba(168, 85, 247, 0.64);
    border-bottom: 2px solid transparent;
    border-left: 2px solid transparent;
    filter: drop-shadow(0 0 18px rgba(34, 211, 238, 0.62));
  }

  .spark-orbit--outer {
    width: min(31rem, 78vw);
    height: min(31rem, 78vw);
    animation: orbit-spin 18s linear infinite;
  }

  .spark-orbit--middle {
