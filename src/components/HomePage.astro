        </figure>
      </div>
    </section>

    <section class="border-y border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900/55" aria-label={locale === "de" ? "Unser Arbeitsversprechen" : "How we work"}>
      <div class="container-responsive grid gap-0 md:grid-cols-3">
        {t.signals.map((item) => (
          <div class="border-b border-slate-200 py-6 last:border-b-0 md:border-b-0 md:border-r md:px-8 md:first:pl-0 md:last:border-r-0 md:last:pr-0" data-reveal>
            <p class="font-semibold text-slate-950 dark:text-slate-50">{item.title}</p>
            <p class="mt-1 max-w-sm text-sm leading-6 text-slate-600 dark:text-slate-400">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section-spacing bg-white dark:bg-slate-950">
      <div class="container-responsive grid items-start gap-10 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:gap-16">
