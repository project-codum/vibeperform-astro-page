          <h2 class="max-w-[15ch] text-3xl font-semibold leading-tight tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">
            {t.promise.heading}
          </h2>
          <p class="mt-5 max-w-[56ch] text-base leading-7 text-slate-600 dark:text-slate-400 sm:text-lg">
            {t.promise.body}
          </p>
          <img
            src={assetUrl("/workshop2.webp")}
            alt={t.promise.imageAlt}
            class="mt-8 aspect-[16/9] w-full rounded-2xl object-cover"
            width="1900"
            height="700"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="border-t border-slate-200 dark:border-slate-800">
          {t.promise.points.map((item) => (
            <article class="grid gap-3 border-b border-slate-200 py-7 sm:grid-cols-[2.5rem_1fr] dark:border-slate-800" data-reveal>
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-purple-100 text-purple-800 dark:bg-purple-950 dark:text-purple-200" aria-hidden="true" set:html={renderIcon(Check, "h-4 w-4")} />
