        {
          title: "Büroarbeit verlässlich abnehmen",
          body: "Belege, Protokolle und Anfragen werden erfasst, geprüft und an die richtige Stelle weitergegeben.",
          image: "/workshop3.webp",
          imageAlt: "Ruhiger Besprechungsraum für die gemeinsame Prozessarbeit",
        },
      ],
    },
    boundaries: {
      heading: "Was Sie von uns nicht bekommen.",
      items: [
