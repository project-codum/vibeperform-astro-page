                <h3 class="text-xl font-semibold text-slate-950 dark:text-slate-50">{item.title}</h3>
                <p class="mt-2 max-w-[52ch] text-base leading-7 text-slate-600 dark:text-slate-400">{item.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id={locale === "de" ? "so-arbeiten-wir" : "how-we-work"} class="section-spacing bg-[#2a1838] text-purple-50">
      <div class="container-responsive">
        <div class="max-w-3xl" data-reveal>
          <h2 class="text-3xl font-semibold tracking-[-0.035em] text-[#fffafc] sm:text-4xl lg:text-5xl">
            {t.process.heading}
          </h2>
          <p class="mt-4 max-w-[60ch] text-base leading-7 text-[#f0e7f5] sm:text-lg">
            {t.process.intro}
          </p>
        </div>
        <div class="mt-12 grid gap-x-12 gap-y-0 md:grid-cols-2">
          {t.process.steps.map((step) => (
            <article class="border-t border-[#76578a] py-7" data-reveal>
              <h3 class="text-xl font-semibold text-[#fffafc]">{step.title}</h3>
              <p class="mt-2 max-w-[52ch] text-sm leading-6 text-[#e7daef] sm:text-base sm:leading-7">{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-spacing bg-[#eeebf4] dark:bg-[#18131e]">
      <div class="container-responsive">
        <div class="max-w-3xl" data-reveal>
          <h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">
            {t.uses.heading}
          </h2>
          <p class="mt-4 max-w-[60ch] text-base leading-7 text-slate-600 dark:text-slate-400 sm:text-lg">
            {t.uses.intro}
          </p>
        </div>
        <div class="mt-12 grid gap-5 md:grid-cols-2 md:grid-rows-2">
          {t.uses.items.map((item, index) => (
            "image" in item ? (
              <article class:list={["overflow-hidden rounded-2xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900", index === 1 && "md:row-span-2"]} data-reveal>
                <img
                  src={assetUrl(item.image)}
                  alt={item.imageAlt}
                  class:list={["w-full object-cover", index === 1 ? "aspect-[4/3] md:h-[58%]" : "aspect-[16/8] md:h-[52%]"]}
                  width={index === 1 ? "650" : "1440"}
                  height={index === 1 ? "433" : "1080"}
                  loading="lazy"
                  decoding="async"
                />
                <div class="p-6 sm:p-7">
                  <h3 class="text-xl font-semibold text-slate-950 dark:text-slate-50 sm:text-2xl">{item.title}</h3>
                  <p class="mt-3 max-w-[48ch] text-sm leading-6 text-slate-600 dark:text-slate-400 sm:text-base">{item.body}</p>
                </div>
              </article>
            ) : (
              <article class="rounded-2xl border border-[#c8b4d8] bg-[#ded2e8] p-7 dark:border-purple-900 dark:bg-purple-950/65 sm:p-9" data-reveal>
                <h3 class="max-w-[17ch] text-2xl font-semibold tracking-[-0.025em] text-slate-950 dark:text-slate-50 sm:text-3xl">{item.title}</h3>
                <p class="mt-4 max-w-[48ch] text-base leading-7 text-slate-700 dark:text-slate-300">{item.body}</p>
              </article>
            )
          ))}
        </div>
      </div>
    </section>

    <section class="section-spacing bg-slate-50 dark:bg-slate-900/55">
      <div class="container-responsive grid gap-10 md:grid-cols-[0.82fr_1.18fr] md:gap-16">
        <h2 class="max-w-[13ch] text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl" data-reveal>
          {boundaryHeadingBefore}<span class="text-purple-700 underline decoration-2 decoration-purple-500 underline-offset-[0.16em] dark:text-purple-300 dark:decoration-purple-400">{boundaryEmphasis}</span>{boundaryHeadingAfter}
        </h2>
        <ul class="border-t border-slate-300 dark:border-slate-700">
          {t.boundaries.items.map((item) => (
            <li class="flex gap-4 border-b border-slate-300 py-5 text-base font-medium leading-7 text-slate-800 dark:border-slate-700 dark:text-slate-200" data-reveal>
              <span aria-hidden="true" set:html={renderIcon(Check, "mt-1 h-5 w-5 shrink-0 text-purple-700 dark:text-purple-300")} />
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section-spacing bg-white dark:bg-slate-950">
      <div class="container-responsive grid items-end gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
        <div data-reveal>
          <h2 class="max-w-[13ch] text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">
            {t.team.heading}
          </h2>
          <p class="mt-5 max-w-[48ch] text-base leading-7 text-slate-600 dark:text-slate-400 sm:text-lg">{t.team.body}</p>
          <a class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-purple-800 underline decoration-purple-300 underline-offset-4 hover:text-purple-950 dark:text-purple-200 dark:decoration-purple-700 dark:hover:text-purple-100" href={t.team.linkHref}>
            {t.team.linkLabel}
            <span aria-hidden="true" set:html={renderIcon(ArrowRight, "h-4 w-4")} />
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4 sm:gap-6">
          {t.team.members.map((member) => (
            <figure data-reveal>
              <img
                src={assetUrl(member.image)}
                alt={member.name}
                class="aspect-[4/5] w-full rounded-2xl object-cover object-top"
                width={member.name.startsWith("Marlon") ? "574" : "1280"}
                height={member.name.startsWith("Marlon") ? "861" : "1920"}
                loading="lazy"
                decoding="async"
              />
              <figcaption class="mt-3">
                <p class="font-semibold text-slate-950 dark:text-slate-50">{member.name}</p>
                <p class="mt-0.5 text-sm text-slate-600 dark:text-slate-400">{member.role}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="pb-20 pt-4 sm:pb-28">
      <div class="container-responsive">
        <div class="rounded-2xl border border-purple-200 bg-purple-50 px-6 py-10 dark:border-purple-900 dark:bg-purple-950/65 sm:px-10 sm:py-12 lg:px-14" data-reveal>
          <h2 class="max-w-[18ch] text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">
            {t.final.heading}
          </h2>
          <p class="mt-4 max-w-[60ch] text-base leading-7 text-slate-700 dark:text-slate-300 sm:text-lg">{t.final.body}</p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <Button href={hero.primaryHref}>{hero.primaryCta}</Button>
            <a
              class="inline-flex min-h-12 w-full items-center justify-center rounded-full border border-purple-300 px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-purple-500 hover:bg-white active:scale-[0.98] dark:border-purple-800 dark:text-slate-100 dark:hover:border-purple-600 dark:hover:bg-purple-950 sm:w-auto"
              href={t.final.secondaryHref}
            >
              {t.final.secondaryLabel}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer currentLocale={locale} />
</div>

<script>
  const setupHomeReveals = () => {
    const root = document.querySelector("[data-home-hero]")?.closest(".home-shell");
    if (!(root instanceof HTMLElement) || root.dataset.revealsReady === "true") return;

    root.dataset.revealsReady = "true";
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const items = Array.from(root.querySelectorAll("[data-reveal]"));

    if (reduceMotion || !("IntersectionObserver" in window)) {
      items.forEach((item) => item.classList.add("is-visible"));
      return;
    }

    root.classList.add("reveal-ready");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { rootMargin: "0px 0px -8%", threshold: 0.12 },
    );

    items.forEach((item) => observer.observe(item));
  };

  if (document.readyState === "loading") {
