---
import {
  ArrowRight,
  Check,
  ShieldCheck,
} from "lucide-static";
import Button from "./Button.astro";
import Footer from "./Footer.astro";
import NavBar from "./NavBar.astro";
import type { HomeContent } from "../data/homeContent";

interface Props {
  content: HomeContent;
  currentLocale: string;
  alternateLocaleHref: string;
}

const { content, currentLocale, alternateLocaleHref } = Astro.props as Props;
const { nav, hero } = content;
const locale = currentLocale === "de" ? "de" : "en";
const basePath = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
const homeHref = locale === "de" ? `${basePath}/de/` : `${basePath}/en/`;
const assetUrl = (path: string) => `${basePath}${path}`;

const renderIcon = (iconSvg: string, className: string) =>
  iconSvg
    .replace('class="lucide', `class="lucide ${className}`)
    .replace('width="24"', 'width="24"')
    .replace('height="24"', 'height="24"');

const pageCopy = {
  de: {
    heroAlt:
      "Handwerksmeister und Berater besprechen gemeinsam einen Arbeitsablauf in einer Schreinerei",
    heroNote: "Beratung und Umsetzung aus einer Hand",
    signals: [
      {
        title: "Vor Ort",
        body: "Wir verstehen den Ablauf, bevor wir Technik empfehlen.",
      },
      {
        title: "Unabhängig",
