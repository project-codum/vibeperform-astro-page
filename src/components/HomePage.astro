    promise: {
      heading: "No AI theatre. Clear improvements at work.",
      body: "Our work starts where time, knowledge or quality gets lost, not with a tool.",
      points: [
        {
          title: "Understand the work",
          body: "We speak with the people who do the job every day.",
        },
        {
          title: "Make a sound decision",
          body: "You get a clear recommendation: buy, adapt, build or deliberately leave it alone.",
        },
        {
          title: "Implement it properly",
          body: "We develop, test and embed the solution together with your team.",
        },
