---
import Button from './Button.astro';
import Footer from './Footer.astro';
import NavBar from './NavBar.astro';
import PageReveals from './PageReveals.astro';
import { CheckCircle2 } from 'lucide-static';
import type { AboutContent } from '../data/aboutContent';

interface Props {
	content: AboutContent;
	homeHref: string;
	alternateLocaleHref: string;
	currentLocale: 'en' | 'de';
}

const { content, homeHref, alternateLocaleHref, currentLocale } = Astro.props as Props;
const { nav, hero, approach, team, connect } = content;
const locale = currentLocale === 'de' ? 'de' : 'en';
const assetBaseUrl = import.meta.env.BASE_URL ?? '/';
const checkIcon = CheckCircle2
	.replace('class="lucide', 'class="lucide h-5 w-5')
	.replace('width="24"', 'width="20"')
	.replace('height="24"', 'height="20"');
---

<div class="flex min-h-screen flex-col bg-white text-slate-950 dark:bg-slate-950 dark:text-slate-100">
	<NavBar nav={nav} homeHref={homeHref} alternateLocaleHref={alternateLocaleHref} currentLocale={locale} />

	<main class="about-main flex flex-1 flex-col overflow-hidden">
		<section class="flex min-h-[calc(100dvh-76px)] items-center py-16 lg:py-20">
			<div class="container-responsive grid items-center gap-12 lg:grid-cols-12 lg:gap-12">
				<div class="max-w-3xl lg:col-span-8">
					<p class="text-xs font-semibold uppercase tracking-[0.28em] text-purple-700 dark:text-purple-300 sm:text-sm">{hero.kicker}</p>
					<h1 class="mt-5 max-w-[20ch] text-[clamp(2.35rem,4.25vw,3.25rem)] font-semibold leading-[1.03] tracking-[-0.05em] text-slate-950 dark:text-slate-50">
						{hero.title}
					</h1>
					<p class="mt-6 max-w-[55ch] text-lg leading-8 text-slate-600 dark:text-slate-300 sm:text-xl">{hero.intro}</p>
					<p class="mt-8 max-w-[52ch] border-l-2 border-purple-600 pl-5 text-base font-semibold leading-7 text-slate-900 dark:border-purple-400 dark:text-slate-100 sm:text-lg">
						{hero.promise}
					</p>
				</div>

				<figure class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-[0_24px_70px_rgba(42,24,56,0.14)] dark:border-slate-800 dark:bg-slate-900 lg:col-span-4">
					<img
						src="/workshop3-720.webp"
						alt={locale === 'de' ? 'Workshop-Raum mit Whiteboard und Vibeperform Bildschirm' : 'Workshop room with a whiteboard and Vibeperform screen'}
						class="aspect-[16/9] w-full object-cover lg:aspect-[3/4]"
						loading="eager"
						fetchpriority="high"
						decoding="sync"
						width="720"
						height="540"
					/>
				</figure>
			</div>
		</section>

		<section class="section-spacing bg-[#eeebf4] dark:bg-[#18131e]">
			<div class="container-responsive">
				<div class="max-w-3xl" data-page-reveal>
					<p class="text-xs font-semibold uppercase tracking-[0.28em] text-purple-700 dark:text-purple-300 sm:text-sm">{team.kicker}</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">{team.title}</h2>
					<p class="mt-5 max-w-[60ch] text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg sm:leading-8">
						{locale === 'de'
							? 'Technologie, Produktdenken und Veränderungskompetenz kommen bei uns an einem Tisch zusammen.'
							: 'Technology, product thinking, and change expertise come together at one table.'}
					</p>
				</div>

				<div class="mt-12 grid gap-7 lg:grid-cols-2">
					{team.members.map((member) => (
						<article class="overflow-hidden rounded-2xl border border-[#c8b4d8] bg-white dark:border-[#4a3659] dark:bg-[#241b2c]" data-page-reveal>
							{member.image ? (
								<img
									class="aspect-[4/3] w-full object-cover object-top"
									src={`${assetBaseUrl}${member.image.src}`}
									alt={member.image.alt}
									loading="lazy"
									width="720"
									height="540"
								/>
							) : null}
							<div class="p-6 sm:p-8">
								<header>
									<h3 class="text-2xl font-semibold tracking-[-0.025em] text-slate-950 dark:text-slate-50 sm:text-3xl">{member.name}</h3>
									<p class="mt-2 text-sm font-medium text-purple-800 dark:text-purple-300">{member.tagline}</p>
								</header>
								<div class="mt-6 space-y-4 text-base leading-7 text-slate-600 dark:text-slate-300">
									{member.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
								</div>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section-spacing bg-[#2a1838] text-purple-50">
			<div class="container-responsive">
				<div class="max-w-3xl" data-page-reveal>
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-[#fffafc] sm:text-4xl lg:text-5xl">{approach.title}</h2>
					<p class="mt-5 max-w-[60ch] text-base leading-7 text-[#d9cae6] sm:text-lg sm:leading-8">{approach.intro}</p>
				</div>

				<div class="mt-12 grid gap-x-10 gap-y-0 md:grid-cols-3">
					{approach.steps.map((step) => (
						<article class="border-t border-[#76578a] py-7" data-page-reveal>
							<span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-[#4b2e5c] text-purple-100" aria-hidden="true" set:html={checkIcon} />
							<p class="mt-5 text-base leading-7 text-[#f0e8f5]">{step}</p>
						</article>
					))}
				</div>

				<p class="mt-7 max-w-3xl text-lg font-semibold leading-8 text-[#fffafc]" data-page-reveal>{approach.closing}</p>
			</div>
		</section>

		<section class="section-spacing bg-white dark:bg-slate-950">
			<div class="container-responsive" data-page-reveal>
				<div class="grid items-center gap-8 rounded-2xl bg-[#eeebf4] p-7 dark:bg-[#18131e] sm:p-10 lg:grid-cols-[1fr_auto] lg:p-12">
					<div class="max-w-2xl">
						<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl">{connect.title}</h2>
						<p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg">{connect.body}</p>
					</div>
					<div class="lg:justify-self-end">
						<Button href={connect.button.href} target="_blank" rel="noreferrer noopener">{connect.button.label}</Button>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer currentLocale={locale} />
	<PageReveals />
</div>

<style>
	.about-main {
		padding-inline: 0;
	}
</style>
