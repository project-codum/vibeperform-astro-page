---
import { homeContent } from '../data/homeContent';

type Locale = 'en' | 'de';

interface Props {
	currentLocale?: Locale;
}

const { currentLocale } = Astro.props as Props;
const locale: Locale = currentLocale === 'de' ? 'de' : 'en';
const nav = homeContent[locale].nav ?? homeContent.en.nav;
const year = new Date().getFullYear();

const copy = {
	en: {
		tagline: 'We partner with operators to design, build, and embed AI that teams actually use.',
		linksLabel: 'Explore',
		legalLinksLabel: 'Legal',
		contactLabel: 'Contact',
		contactIntro: 'Say hello or share what you are working on.',
		locationLabel: 'Where we work',
		location: 'Munich & on-site in the region',
		emailLabel: 'Email',
		actionLabel: 'Book an intro call',
		actionHref: 'https://calendar.app.google/utFQgw33PwJTiDk56',
		legal: 'All rights reserved.',
		legalLinks: [
			{ label: 'Legal notice', href: '/en/legal-notice' },
			{ label: 'Privacy', href: '/en/privacy' },
		],
	},
	de: {
		tagline: 'Wir begleiten Teams dabei, Mehrwerte durch KI zu erkennen und umzusetzen.',
		linksLabel: 'Entdecken',
		legalLinksLabel: 'Rechtliches',
		contactLabel: 'Kontakt',
		contactIntro: 'Erzähl uns, woran ihr arbeitet.',
		locationLabel: 'Wo wir arbeiten',
		location: 'München & Umgebung',
		emailLabel: 'E-Mail',
		actionLabel: 'Erstgespräch buchen',
		actionHref: 'https://calendar.app.google/utFQgw33PwJTiDk56',
		legal: 'Alle Rechte vorbehalten.',
		legalLinks: [
			{ label: 'Impressum', href: '/de/impressum' },
			{ label: 'Datenschutz', href: '/de/datenschutz' },
		],
	},
} as const;

const localizedCopy = copy[locale];
---

<footer class="mt-auto border-t border-slate-200 bg-slate-50 text-slate-900 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100">
	<div class="container-responsive py-12">
		<div class="flex flex-col gap-10 md:flex-row md:justify-between">
			<div class="max-w-sm space-y-5">
				<p class="text-base font-semibold text-slate-950 dark:text-slate-50">{nav.brand}</p>
				<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">{localizedCopy.tagline}</p>
					<a
						class="inline-flex w-full items-center justify-center whitespace-nowrap rounded-full border border-transparent bg-purple-700 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-purple-800 active:scale-[0.98] dark:bg-purple-500 dark:text-slate-950 dark:hover:bg-purple-400 sm:w-auto"
						href={localizedCopy.actionHref}
					>
						{localizedCopy.actionLabel}
					</a>
			</div>

			<div class="grid gap-10 sm:grid-cols-3">
				<div>
					<p class="text-sm font-semibold text-slate-950 dark:text-slate-100">{localizedCopy.linksLabel}</p>
					<ul class="mt-4 space-y-2 text-sm text-slate-600 dark:text-slate-300">
						{nav.links.map((link) => (
							<li>
								<a class="hover:text-slate-950 dark:hover:text-white" href={link.href}>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>

				<div>
					<p class="text-sm font-semibold text-slate-950 dark:text-slate-100">{localizedCopy.legalLinksLabel}</p>
					<ul class="mt-4 space-y-2 text-sm text-slate-600 dark:text-slate-300">
						{localizedCopy.legalLinks.map((link) => (
							<li>
								<a class="hover:text-slate-950 dark:hover:text-white" href={link.href}>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>

				<div class="space-y-4 text-sm text-slate-600 dark:text-slate-300">
					<div>
						<p class="text-sm font-semibold text-slate-950 dark:text-slate-100">{localizedCopy.contactLabel}</p>
						<p class="mt-3 text-slate-600 dark:text-slate-300">{localizedCopy.contactIntro}</p>
					</div>
					<dl class="space-y-3">
						<div>
							<dt class="text-xs font-semibold text-slate-500 dark:text-slate-400">{localizedCopy.emailLabel}</dt>
							<dd>
								<a class="hover:text-slate-950 dark:hover:text-white" href="mailto:contact@vibeperform.com">contact@vibeperform.com</a>
							</dd>
						</div>
						<div>
							<dt class="text-xs font-semibold text-slate-500 dark:text-slate-400">{localizedCopy.locationLabel}</dt>
							<dd class="text-slate-600 dark:text-slate-300">{localizedCopy.location}</dd>
						</div>
					</dl>
				</div>
			</div>
		</div>

		<div class="mt-12 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-800">
			<p>© {year} {nav.brand}. {localizedCopy.legal}</p>
		</div>
	</div>
</footer>
