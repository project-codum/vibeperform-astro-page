---
import type { HomeContent } from '../data/homeContent';
import { Menu } from 'lucide-static';

type NavContent = HomeContent['nav'];

interface Props {
	nav: NavContent;
	homeHref: string;
	alternateLocaleHref: string;
	currentLocale: 'de' | 'en';
}

const { nav, homeHref, alternateLocaleHref, currentLocale } = Astro.props as Props;
const alternateLocale = currentLocale === 'de' ? 'en' : 'de';
const baseUrl = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const logoUrl = `${baseUrl}/vibeperform-logo.png`;
const logoAnimationUrl = `${baseUrl}/vibeperform-logo-alive.json`;
const toggleId = `nav-toggle-${Math.random().toString(36).slice(2, 9)}`;
const menuId = `nav-menu-${Math.random().toString(36).slice(2, 9)}`;
const menuIcon = Menu
	.replace('class="lucide', 'class="lucide h-5 w-5')
	.replace('width="24"', 'width="20"')
	.replace('height="24"', 'height="20"');
---

<header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/95 backdrop-blur dark:border-slate-800 dark:bg-slate-950/95">
	<nav class="container-responsive flex h-[76px] items-center justify-between gap-4">
		<a
			class="inline-flex items-center rounded-xl dark:bg-white dark:px-2"
			href={homeHref}
			aria-label={nav.brand}
		>
			<span
				class="nav-logo-lottie"
				data-logo-lottie={logoAnimationUrl}
				aria-hidden="true"
			>
				<img
					src={logoUrl}
					alt=""
					class="nav-logo-lottie__fallback"
					height="214"
					width="505"
					loading="eager"
					decoding="async"
					data-logo-fallback
				/>
				<span class="nav-logo-lottie__stage" data-logo-lottie-stage></span>
			</span>
		</a>

		<div class="hidden items-center gap-7 md:flex">
			{nav.links.map((link) => (
				<a
					class="text-sm font-semibold text-slate-600 hover:text-slate-950 dark:text-slate-300 dark:hover:text-white"
					href={link.href}
				>
					{link.label}
				</a>
			))}
			<a
				class="inline-flex min-h-10 items-center justify-center rounded-full border border-slate-300 px-4 text-sm font-semibold text-slate-700 hover:border-slate-500 hover:text-slate-950 active:scale-[0.98] dark:border-slate-700 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white"
				href={alternateLocaleHref}
				aria-label={nav.toggleAriaLabel}
				data-locale-switch
				data-target-locale={alternateLocale}
			>
				{nav.toggleLabel}
			</a>
		</div>

		<button
			id={toggleId}
			class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-300 text-slate-700 hover:border-slate-500 hover:text-slate-950 active:scale-[0.98] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple-500 dark:border-slate-700 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white md:hidden"
			type="button"
			aria-expanded="false"
			aria-controls={menuId}
			aria-label={nav.menuToggleLabel}
			data-nav-toggle
		>
			<span class="sr-only">{nav.menuToggleLabel}</span>
			<span aria-hidden="true" set:html={menuIcon} />
		</button>
	</nav>

	<div
		id={menuId}
		class="container-responsive mt-3 grid gap-2 rounded-2xl border border-slate-200 bg-white p-4 shadow-lg dark:border-slate-800 dark:bg-slate-900 md:hidden"
		data-open="false"
		data-nav-menu
		aria-hidden="true"
		hidden
	>
		{nav.links.map((link) => (
			<a
				class="rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800"
				href={link.href}
			>
				{link.label}
			</a>
		))}
		<a
			class="mt-2 inline-flex min-h-11 items-center justify-center rounded-full border border-slate-300 px-4 text-sm font-semibold text-slate-700 hover:border-slate-500 hover:text-slate-950 dark:border-slate-700 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white"
			href={alternateLocaleHref}
			aria-label={nav.toggleAriaLabel}
			data-locale-switch
			data-target-locale={alternateLocale}
		>
			{nav.toggleLabel}
		</a>
	</div>
</header>

<div class="cursor-orbit" data-cursor-orbit aria-hidden="true">
	<div class="cursor-orbit__visual">
		<span class="cursor-orbit__halo"></span>
		<span class="cursor-orbit__nodes">
			<span class="cursor-orbit__node cursor-orbit__node--one"></span>
			<span class="cursor-orbit__node cursor-orbit__node--two"></span>
			<span class="cursor-orbit__node cursor-orbit__node--three"></span>
		</span>
	</div>
</div>

<style>
	.nav-logo-lottie {
		display: block;
		position: relative;
		width: 10.5rem;
		height: 3.5rem;
		overflow: hidden;
	}

	@media (min-width: 768px) {
		.nav-logo-lottie {
			width: 12rem;
			height: 4rem;
		}
	}

	.nav-logo-lottie__stage,
	.nav-logo-lottie__fallback {
		display: block;
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		transform: scale(1.7);
		transform-origin: center;
	}

	.nav-logo-lottie__stage :global(svg),
	.nav-logo-lottie__stage :global(canvas) {
		display: block;
		width: 100% !important;
		height: 100% !important;
	}

	.nav-logo-lottie__fallback {
		object-fit: contain;
	}

	.nav-logo-lottie[data-logo-status='ready'] .nav-logo-lottie__fallback {
		display: none;
	}

	.cursor-orbit {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 50;
		width: 0;
		height: 0;
		pointer-events: none;
		visibility: hidden;
		opacity: 0;
		transition:
			opacity 160ms ease,
			visibility 0s linear 160ms;
	}

	.cursor-orbit[data-visible='true'] {
		visibility: visible;
		opacity: 1;
		transition-delay: 0s;
	}

	.cursor-orbit__visual {
		position: absolute;
		top: 0;
		left: 0;
		width: 3.5rem;
		height: 3.5rem;
		transform: translate(-50%, -50%);
	}

	.cursor-orbit__halo,
	.cursor-orbit__nodes,
	.cursor-orbit__node {
		position: absolute;
		inset: 0;
		border-radius: 9999px;
	}

	.cursor-orbit__halo {
		inset: 0.42rem;
		border: 1.5px solid rgb(158 66 255 / 32%);
		box-shadow: 0 0 1rem rgb(158 66 255 / 10%);
		animation: cursor-halo-breathe 4s ease-in-out infinite;
		animation-play-state: paused;
	}

	.cursor-orbit__nodes {
		animation: cursor-node-orbit 6s linear infinite;
		animation-play-state: paused;
	}

	.cursor-orbit[data-visible='true'] .cursor-orbit__halo,
	.cursor-orbit[data-visible='true'] .cursor-orbit__nodes {
		animation-play-state: running;
	}

	.cursor-orbit__node::after {
		position: absolute;
		top: 0.08rem;
		left: 50%;
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 9999px;
		background: rgb(219 189 255);
		box-shadow: 0 0 0.65rem rgb(158 66 255 / 38%);
		content: '';
		transform: translateX(-50%);
	}

	.cursor-orbit__node--two {
		transform: rotate(120deg);
	}

	.cursor-orbit__node--three {
		transform: rotate(240deg);
	}

	.cursor-orbit__node--three::after {
		background: rgb(184 117 255);
	}

	@keyframes cursor-node-orbit {
		to {
			transform: rotate(1turn);
		}
	}

	@keyframes cursor-halo-breathe {
		0%,
		100% {
			opacity: 0.42;
			transform: scale(0.82);
		}

		50% {
			opacity: 0.9;
			transform: scale(1.12);
		}
	}

	@media (max-width: 767px), (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
		.cursor-orbit {
			display: none;
		}
	}

	@media (min-width: 768px) and (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
		.cursor-orbit {
			will-change: transform, opacity;
		}
	}

	[data-nav-menu] {
		--nav-transition-duration: 220ms;
		overflow: hidden;
		max-height: 0;
		transform: translateY(-0.35rem);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			max-height var(--nav-transition-duration) ease,
			opacity var(--nav-transition-duration) ease,
			transform var(--nav-transition-duration) ease,
			visibility 0s linear var(--nav-transition-duration);
	}

	[data-nav-menu][data-open='true'] {
		max-height: 20rem;
		opacity: 1;
		transform: translateY(0);
		visibility: visible;
		pointer-events: auto;
		transition:
			max-height var(--nav-transition-duration) ease,
			opacity var(--nav-transition-duration) ease,
			transform var(--nav-transition-duration) ease;
	}
</style>

<script>
	const activeLogoAnimations = new Map();
	let lottieImportPromise;

	const destroyLogoAnimations = () => {
		activeLogoAnimations.forEach((animation, container) => {
			animation.destroy();
			container.removeAttribute('data-logo-status');
			container.removeAttribute('data-logo-initialized');
		});
		activeLogoAnimations.clear();
	};

	const loadLottie = () => {
		lottieImportPromise ??= import('lottie-web/build/player/lottie_light').then(
			(module) => module.default
		);

		return lottieImportPromise;
	};

	const setupLogoAnimations = async () => {
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const hasDesktopViewport = window.matchMedia('(min-width: 768px)').matches;

		if (reduceMotion || !hasDesktopViewport) {
			return;
		}

		const lottie = await loadLottie();

		document.querySelectorAll('[data-logo-lottie]').forEach((container) => {
			if (!(container instanceof HTMLElement) || container.dataset.logoInitialized === 'true') {
				return;
			}

			const animationPath = container.dataset.logoLottie;
			const stage = container.querySelector('[data-logo-lottie-stage]');
			if (!animationPath || !(stage instanceof HTMLElement)) {
				return;
			}

			container.dataset.logoInitialized = 'true';

			const animation = lottie.loadAnimation({
				container: stage,
				renderer: 'svg',
				loop: !reduceMotion,
				autoplay: !reduceMotion,
				path: animationPath,
				rendererSettings: {
					preserveAspectRatio: 'xMidYMid meet',
					progressiveLoad: true,
				},
			});

			activeLogoAnimations.set(container, animation);

			animation.addEventListener('DOMLoaded', () => {
				container.dataset.logoStatus = 'ready';

				if (reduceMotion) {
					animation.goToAndStop(60, true);
				}
			});

			animation.addEventListener('data_failed', () => {
				animation.destroy();
				activeLogoAnimations.delete(container);
				container.dataset.logoStatus = 'fallback';
			});
		});
	};

	const scheduleLogoAnimations = () => {
		const start = () => {
			void setupLogoAnimations();
		};

		if ('requestIdleCallback' in window) {
			window.requestIdleCallback(start, { timeout: 1800 });
			return;
		}

		window.setTimeout(start, 900);
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', scheduleLogoAnimations, { once: true });
	} else {
		scheduleLogoAnimations();
	}

	document.addEventListener('astro:page-load', scheduleLogoAnimations);
	document.addEventListener('astro:before-swap', destroyLogoAnimations);
</script>

<script>
	let destroyCursorOrbit;
	const cursorMediaQuery =
		'(min-width: 768px) and (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)';

	const setupCursorOrbit = () => {
		const cursor = document.querySelector('[data-cursor-orbit]');
		if (!(cursor instanceof HTMLElement) || cursor.dataset.cursorInitialized === 'true') {
			return;
		}

		cursor.dataset.cursorInitialized = 'true';
		const media = window.matchMedia(cursorMediaQuery);
		let deactivate = () => {};

		const syncCursor = () => {
			deactivate();
			deactivate = () => {};

			if (!media.matches) {
				return;
			}

			let animationFrame = 0;
			let currentX = 0;
			let currentY = 0;
			let targetX = 0;
			let targetY = 0;
			let lastFrameTime = 0;
			let hasPosition = false;

			const render = (time) => {
				animationFrame = 0;
				const delta = lastFrameTime ? Math.min(time - lastFrameTime, 32) : 16.7;
				const smoothing = 1 - Math.exp(-delta / 48);
				lastFrameTime = time;
				currentX += (targetX - currentX) * smoothing;
				currentY += (targetY - currentY) * smoothing;
				cursor.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;

				if (Math.abs(targetX - currentX) > 0.1 || Math.abs(targetY - currentY) > 0.1) {
					animationFrame = window.requestAnimationFrame(render);
				}
			};

			const scheduleRender = () => {
				if (!animationFrame) {
					lastFrameTime = 0;
					animationFrame = window.requestAnimationFrame(render);
				}
			};

			const show = () => {
				cursor.dataset.visible = 'true';
			};

			const hide = () => {
				cursor.removeAttribute('data-visible');
				hasPosition = false;
				lastFrameTime = 0;
				if (animationFrame) {
					window.cancelAnimationFrame(animationFrame);
					animationFrame = 0;
				}
			};

			const move = (event) => {
				targetX = event.clientX;
				targetY = event.clientY;

				if (!hasPosition) {
					currentX = targetX;
					currentY = targetY;
					cursor.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;
					hasPosition = true;
					show();
					return;
				}

				scheduleRender();
			};

			const leaveWindow = (event) => {
				if (event.relatedTarget === null) {
					hide();
				}
			};

			document.addEventListener('pointermove', move, { passive: true });
			document.addEventListener('pointerout', leaveWindow, { passive: true });
			window.addEventListener('blur', hide);

			deactivate = () => {
				document.removeEventListener('pointermove', move);
				document.removeEventListener('pointerout', leaveWindow);
				window.removeEventListener('blur', hide);
				hide();
				cursor.style.removeProperty('transform');
			};
		};

		media.addEventListener('change', syncCursor);
		syncCursor();

		destroyCursorOrbit = () => {
			deactivate();
			media.removeEventListener('change', syncCursor);
			cursor.dataset.cursorInitialized = 'false';
			destroyCursorOrbit = undefined;
		};
	};

	const cleanupCursorOrbit = () => {
		destroyCursorOrbit?.();
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupCursorOrbit, { once: true });
	} else {
		setupCursorOrbit();
	}

	document.addEventListener('astro:page-load', setupCursorOrbit);
	document.addEventListener('astro:before-swap', cleanupCursorOrbit);
</script>

<script is:inline>
	(() => {
		const focusableSelector =
			'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"]), [data-nav-focusable="true"]';

		const setupNav = (toggle, menu) => {
			if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) {
				return;
			}

			if (menu.dataset.navInitialized === 'true') {
				return;
			}
			menu.dataset.navInitialized = 'true';

			let isExpanded = toggle.getAttribute('aria-expanded') === 'true';
			let previousBodyOverflow = document.body.style.overflow || '';

			const focusElement = (element) => {
				if (!(element instanceof HTMLElement)) {
					return;
				}

				try {
					element.focus({ preventScroll: true });
				} catch (_error) {
					element.focus();
				}
			};

			const lockBodyScroll = (lock) => {
				if (lock) {
					previousBodyOverflow = document.body.style.overflow || '';
					document.body.style.overflow = 'hidden';
				} else {
					document.body.style.overflow = previousBodyOverflow;
				}
			};

			const openMenu = () => {
				if (isExpanded) {
					return;
				}
				isExpanded = true;

				menu.hidden = false;
				menu.dataset.open = 'true';
				menu.setAttribute('aria-hidden', 'false');
				toggle.setAttribute('aria-expanded', 'true');
				lockBodyScroll(true);

				const focusable = menu.querySelectorAll(focusableSelector);
				if (focusable.length) {
					window.requestAnimationFrame(() => {
						focusElement(focusable[0]);
					});
				}
			};

			const closeMenu = (focusToggle = true, force = false) => {
				if (!isExpanded) {
					return;
				}
				isExpanded = false;

				menu.dataset.open = 'false';
				menu.setAttribute('aria-hidden', 'true');
				toggle.setAttribute('aria-expanded', 'false');
				lockBodyScroll(false);

				const finalize = () => {
					if (!isExpanded) {
						menu.hidden = true;
					}
				};

				if (force) {
					finalize();
				} else {
					menu.addEventListener(
						'transitionend',
						(event) => {
							if (event.target === menu) {
								finalize();
							}
						},
						{ once: true }
					);
				}

				if (focusToggle) {
					window.requestAnimationFrame(() => {
						focusElement(toggle);
					});
				}
			};

			const handleKeyDown = (event) => {
				if (event.key === 'Escape') {
					closeMenu();
					return;
				}

				if (event.key === 'Tab' && isExpanded) {
					const focusable = Array.from(menu.querySelectorAll(focusableSelector));
					if (!focusable.length) {
						return;
					}

					const first = focusable[0];
					const last = focusable[focusable.length - 1];

					if (event.shiftKey && document.activeElement === first) {
						event.preventDefault();
						focusElement(last);
					} else if (!event.shiftKey && document.activeElement === last) {
						event.preventDefault();
						focusElement(first);
					}
				}
			};

			const handleDocumentClick = (event) => {
				if (!isExpanded) {
					return;
				}

				const target = event.target;
				if (target instanceof Node && (menu.contains(target) || toggle.contains(target))) {
					return;
				}
				closeMenu();
			};

			const handleToggleClick = (event) => {
				event.preventDefault();
				event.stopPropagation();
				if (isExpanded) {
					closeMenu();
				} else {
					openMenu();
				}
			};

			toggle.addEventListener('click', handleToggleClick);

			menu.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', () => {
					closeMenu(false);
				});
			});

			document.addEventListener('keydown', handleKeyDown);
			document.addEventListener('click', handleDocumentClick);

			const mq = window.matchMedia('(min-width: 768px)');
			const handleBreakpointChange = (event) => {
				if (event.matches) {
					closeMenu(false, true);
				}
			};

			if (typeof mq.addEventListener === 'function') {
				mq.addEventListener('change', handleBreakpointChange);
			} else if (typeof mq.addListener === 'function') {
				mq.addListener(handleBreakpointChange);
			}

			const handlePageShow = () => {
				isExpanded = toggle.getAttribute('aria-expanded') === 'true';
				if (!isExpanded) {
					menu.hidden = true;
					menu.dataset.open = 'false';
					menu.setAttribute('aria-hidden', 'true');
				}
			};

			window.addEventListener('pageshow', handlePageShow);

			let isCleaned = false;
			const cleanup = () => {
				if (isCleaned) {
					return;
				}
				isCleaned = true;
				closeMenu(false, true);
				lockBodyScroll(false);
				toggle.removeEventListener('click', handleToggleClick);
				document.removeEventListener('keydown', handleKeyDown);
				document.removeEventListener('click', handleDocumentClick);
				window.removeEventListener('pageshow', handlePageShow);

				if (typeof mq.removeEventListener === 'function') {
					mq.removeEventListener('change', handleBreakpointChange);
				} else if (typeof mq.removeListener === 'function') {
					mq.removeListener(handleBreakpointChange);
				}

				menu.dataset.navInitialized = 'false';
			};

			document.addEventListener('astro:before-swap', cleanup, { once: true });
			window.addEventListener('beforeunload', cleanup, { once: true });
		};

		const toggles = document.querySelectorAll('[data-nav-toggle]');
		toggles.forEach((toggleElement) => {
			if (!(toggleElement instanceof HTMLButtonElement)) {
				return;
			}

			const controls = toggleElement.getAttribute('aria-controls');
			if (!controls) {
				return;
			}

			const menu = document.getElementById(controls);
			if (!menu) {
				return;
			}

			setupNav(toggleElement, menu);
		});

		document.querySelectorAll('[data-locale-switch]').forEach((link) => {
			link.addEventListener('click', () => {
				const targetLocale = link.getAttribute('data-target-locale');
				if (targetLocale !== 'de' && targetLocale !== 'en') {
					return;
				}

				try {
					window.localStorage.setItem('vibeperform:locale', targetLocale);
				} catch (_error) {
					// Ignore storage failures so language switching still works.
				}
			});
		});
	})();
</script>
