---
import Button from './Button.astro';
import Footer from './Footer.astro';
import NavBar from './NavBar.astro';
import { exploreWorkshopContent } from '../data/exploreWorkshopContent';
import { homeContent } from '../data/homeContent';
import { BarChart3, CheckCircle2, DatabaseZap, Route, SearchCheck, Target, Workflow } from 'lucide-static';

type Locale = 'de' | 'en';

interface Props {
	currentLocale?: Locale;
	alternateLocaleHref?: string;
	workshopsHref?: string;
}

const { currentLocale = 'de', alternateLocaleHref, workshopsHref } = Astro.props as Props;
const locale: Locale = currentLocale === 'en' ? 'en' : 'de';
const nav = homeContent[locale].nav;
const calendarHref = 'https://calendar.app.google/utFQgw33PwJTiDk56';
const mailHref = 'mailto:contact@vibeperform.com?subject=Strategic%20Discovery%20Sprint';
const workshopImage = '/explore-workshop/vibeperform-explore-workshop-hero.png';
const roadmapImage = '/explore-workshop/vibeperform-explore-roadmap.png';
const frameworkIcons = [Target, SearchCheck, DatabaseZap, Workflow, Route] as const;
const deliverableIcons = [Route, BarChart3, DatabaseZap] as const;
const renderIcon = (iconSvg: string, className = 'h-5 w-5') =>
	iconSvg
		.replace('class="lucide', `class="lucide ${className}`)
		.replace('width="24"', 'width="20"')
		.replace('height="24"', 'height="20"');

const content = exploreWorkshopContent[locale];
---

<div class="phase-page flex min-h-screen flex-col bg-white text-slate-950">
	<NavBar
		nav={nav}
		homeHref={content.homeHref as string}
		alternateLocaleHref={alternateLocaleHref ?? (content.alternateLocaleHref as string)}
		currentLocale={locale}
	/>

	<main class="phase-main flex flex-1 flex-col gap-y-24 overflow-hidden pb-20">
		<section class="section-spacing pt-2">
			<div class="container-responsive grid gap-12 lg:grid-cols-[0.94fr_1.06fr] lg:items-center">
				<div class="max-w-2xl space-y-6">
				<p class="text-xs font-semibold uppercase tracking-[0.35em] text-slate-500 sm:text-sm">
					{content.phaseLabel}
				</p>
				<h1 class="max-w-[20rem] text-4xl font-semibold tracking-tight text-slate-900 sm:max-w-none sm:text-5xl lg:text-6xl">
					{content.title}
				</h1>
				<p class="text-base text-slate-600 [text-wrap:balance] sm:text-lg md:text-xl">
					{content.subtitle}
				</p>
				<p class="max-w-xl text-sm leading-7 text-slate-500 md:text-base md:leading-8">
					{content.intro}
				</p>
				<div class="flex flex-col gap-3 pt-2 sm:flex-row">
					<Button href={calendarHref}>{content.primaryCta}</Button>
					<a
						class="inline-flex min-h-11 items-center justify-center rounded-full border border-slate-300 px-5 text-center text-sm font-semibold text-slate-800 transition hover:border-purple-300 hover:bg-purple-50 hover:text-purple-700"
						href={`#${content.outcomeId}`}
					>
						{content.secondaryCta}
					</a>
					<a
						class="inline-flex min-h-11 items-center justify-center rounded-full px-5 text-center text-sm font-semibold text-slate-600 transition hover:bg-slate-50 hover:text-slate-950"
						href={workshopsHref ?? (content.workshopsHref as string)}
					>
						{content.backToWorkshops}
					</a>
				</div>
				</div>

				<figure class="relative overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-xl shadow-slate-900/10">
					<div class="absolute inset-x-10 -top-14 h-40 rounded-full bg-purple-300/35 blur-3xl" aria-hidden="true" />
					<img
						src={workshopImage}
						alt={content.heroAlt}
						class="relative aspect-[16/10] w-full object-cover"
						loading="eager"
						decoding="async"
					/>
				</figure>
			</div>
		</section>

		<section class="section-spacing bg-slate-50">
			<div class="container-responsive space-y-10">
				<div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
				<h2 class="text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">
					{content.introTitle}
				</h2>
				<p class="text-base leading-8 text-slate-600 sm:text-lg">{content.introBody}</p>
				</div>
				<div class="grid gap-5 lg:grid-cols-3">
					{content.proofItems.map((item) => (
						<div class="min-h-44 rounded-3xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-purple-200 hover:shadow-lg">
							<strong class="block text-[clamp(2.125rem,4vw,3.25rem)] font-semibold leading-none text-purple-600">{item.stat}</strong>
							<span class="mt-5 block text-sm leading-6 text-slate-600">{item.copy}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<div class="container-responsive">
			<section class="grid items-center gap-12 lg:grid-cols-[1fr_0.86fr]">
				<div class="max-w-2xl">
					<h2 class="text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">
						{content.experienceTitle}
					</h2>
					{content.experienceBody.map((paragraph) => (
						<p class="mt-5 text-lg leading-8 text-slate-600">{paragraph}</p>
					))}
				</div>
				<div class="overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-sm">
					<img
						src={workshopImage}
						alt={content.experienceAlt}
						class="aspect-[4/3] w-full object-cover"
						loading="eager"
						decoding="async"
					/>
				</div>
			</section>

			<section class="mt-24 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-stretch">
				<div class="relative overflow-hidden rounded-3xl bg-slate-900 p-8 text-white shadow-xl shadow-slate-900/10 sm:p-12 lg:p-14">
					<div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-purple-500/25 blur-3xl" aria-hidden="true" />
					<div class="relative">
						<h2 class="text-3xl font-semibold leading-tight sm:text-4xl">{content.frameworkTitle}</h2>
						<p class="mt-6 text-base leading-8 text-slate-300">{content.frameworkBody}</p>
					</div>
				</div>
				<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
					{content.frameworkSteps.map((step, index) => (
						<article class="min-h-64 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-purple-200 hover:shadow-lg xl:min-h-[17rem]">
							<span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-purple-100 text-purple-600" aria-hidden="true">
								<div set:html={renderIcon(frameworkIcons[index] ?? Target)} />
							</span>
							<h3 class="mt-6 text-lg font-semibold leading-snug text-slate-900">{step.title}</h3>
							<p class="mt-4 text-sm leading-6 text-slate-600">{step.copy}</p>
						</article>
					))}
				</div>
			</section>

			<section class="mt-24 grid overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 shadow-sm lg:grid-cols-[1.05fr_0.95fr]">
				<img
					src={roadmapImage}
					alt={content.roadmapAlt}
					class="h-full min-h-[24rem] w-full object-cover lg:min-h-[34rem]"
					loading="lazy"
					decoding="async"
				/>
				<div class="p-8 sm:p-12 lg:p-14">
					<h2 class="text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">{content.priorityTitle}</h2>
					<p class="mt-6 text-base leading-8 text-slate-600">{content.priorityBody}</p>
					<div class="mt-8 grid gap-3" aria-label={content.useCasesLabel}>
						{content.useCases.map((useCase) => (
							<div class="flex min-h-14 items-center gap-4 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
								<span class="inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-purple-100 text-purple-600" aria-hidden="true">
									<div set:html={renderIcon(CheckCircle2, 'h-4 w-4')} />
								</span>
								<span class="text-base text-slate-700">{useCase}</span>
							</div>
						))}
					</div>
				</div>
			</section>

			<section id={content.outcomeId} class="mt-24">
				<div class="max-w-3xl">
					<h2 class="text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">{content.outcomeTitle}</h2>
					<p class="mt-6 text-lg leading-8 text-slate-600">{content.outcomeBody}</p>
				</div>
				<div class="mt-10 grid gap-6 lg:grid-cols-3">
					{content.deliverables.map((item, index) => (
						<article class="min-h-56 rounded-3xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-purple-200 hover:shadow-lg">
							<span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-purple-100 text-purple-600" aria-hidden="true">
								<div set:html={renderIcon(deliverableIcons[index] ?? Route)} />
							</span>
							<h3 class="mt-6 text-xl font-semibold leading-snug text-slate-900">{item.title}</h3>
							<p class="mt-4 text-sm leading-6 text-slate-600">{item.copy}</p>
						</article>
					))}
				</div>
			</section>

			<section class="mt-16 overflow-hidden rounded-3xl bg-slate-900 p-8 text-white shadow-xl shadow-slate-900/10 sm:p-12 lg:p-16">
				<div class="relative">
					<div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-purple-500/25 blur-3xl" aria-hidden="true" />
					<h2 class="relative max-w-3xl text-[clamp(2.125rem,5vw,3.625rem)] font-semibold leading-[1.03]">
						{content.finalTitle}
					</h2>
					<p class="relative mt-6 max-w-2xl text-lg leading-8 text-slate-300">{content.finalBody}</p>
					<a
						class="relative mt-8 inline-flex min-h-12 items-center justify-center rounded-full border border-white bg-white px-6 text-sm font-semibold text-purple-600 shadow-sm transition hover:bg-purple-50 hover:text-purple-700"
						href={mailHref}
					>
						{content.finalCta}
					</a>
				</div>
			</section>
		</div>
	</main>

	<Footer currentLocale={locale} />
</div>

<style>
	.phase-main {
		padding-inline: 0;
	}
</style>
