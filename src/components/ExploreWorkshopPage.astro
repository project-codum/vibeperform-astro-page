---
import Button from './Button.astro';
import AiImageFrame from './AiImageFrame.astro';
import Footer from './Footer.astro';
import NavBar from './NavBar.astro';
import PageReveals from './PageReveals.astro';
import { exploreWorkshopContent } from '../data/exploreWorkshopContent';
import { homeContent } from '../data/homeContent';
import { BarChart3, CheckCircle2, DatabaseZap, Route, SearchCheck, Target, Workflow } from 'lucide-static';

type Locale = 'de' | 'en';

interface Props {
	currentLocale?: Locale;
	alternateLocaleHref?: string;
	workshopsHref?: string;
}

const { currentLocale = 'de', alternateLocaleHref, workshopsHref } = Astro.props as Props;
const locale: Locale = currentLocale === 'en' ? 'en' : 'de';
const nav = homeContent[locale].nav;
const calendarHref = 'https://calendar.app.google/utFQgw33PwJTiDk56';
const mailHref = 'mailto:contact@vibeperform.com?subject=Strategic%20Discovery%20Sprint';
const workshopImage = '/explore-workshop/vibeperform-explore-workshop-hero-1280.webp';
const experienceImage = '/explore-workshop/strategic-discovery-workshop-1280.webp';
const roadmapImage = '/explore-workshop/vibeperform-explore-roadmap-1280.webp';
const frameworkIcons = [Target, SearchCheck, DatabaseZap, Workflow, Route] as const;
const deliverableIcons = [Route, BarChart3, DatabaseZap] as const;
const renderIcon = (iconSvg: string, className = 'h-5 w-5') =>
	iconSvg
		.replace('class="lucide', `class="lucide ${className}`)
		.replace('width="24"', 'width="20"')
		.replace('height="24"', 'height="20"');

const content = exploreWorkshopContent[locale];
const photoDisclosure = locale === 'de' ? 'Symbolbild, KI-generiert' : 'Illustrative image, AI-generated';
const illustrationDisclosure = locale === 'de' ? 'KI-generierte Illustration' : 'AI-generated illustration';
---

<div class="flex min-h-screen flex-col bg-white text-slate-950 dark:bg-slate-950 dark:text-slate-100">
	<NavBar
		nav={nav}
		homeHref={content.homeHref as string}
		alternateLocaleHref={alternateLocaleHref ?? (content.alternateLocaleHref as string)}
		currentLocale={locale}
	/>

	<main class="explore-main flex flex-1 flex-col overflow-hidden">
		<section class="flex min-h-[calc(100dvh-76px)] items-center py-14 lg:py-18">
			<div class="container-responsive grid items-center gap-12 lg:grid-cols-12 lg:gap-12">
				<div class="max-w-3xl lg:col-span-7">
					<p class="text-xs font-semibold uppercase tracking-[0.28em] text-purple-700 dark:text-purple-300 sm:text-sm">{content.phaseLabel}</p>
					<h1 class="mt-5 max-w-[18ch] text-[clamp(2.75rem,4.6vw,3.9rem)] font-semibold leading-[1.02] tracking-[-0.055em] text-slate-950 dark:text-slate-50">
						{content.title}
					</h1>
					<p class="mt-6 max-w-[46ch] text-lg leading-8 text-slate-600 dark:text-slate-300 sm:text-xl">{content.subtitle}</p>
					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<Button href={calendarHref}>{content.primaryCta}</Button>
						<a
							class="inline-flex min-h-12 w-full items-center justify-center whitespace-nowrap rounded-full border border-purple-300 px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-purple-500 hover:bg-purple-50 active:scale-[0.98] dark:border-purple-800 dark:text-slate-100 dark:hover:border-purple-600 dark:hover:bg-purple-950 sm:w-auto"
							href={`#${content.outcomeId}`}
						>
							{content.secondaryCta}
						</a>
					</div>
				</div>

				<figure class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-[0_24px_70px_rgba(42,24,56,0.14)] dark:border-slate-800 dark:bg-slate-900 lg:col-span-5">
					<AiImageFrame label={photoDisclosure}>
						<picture>
							<source
								type="image/webp"
								srcset="/explore-workshop/vibeperform-explore-workshop-hero-720.webp 720w, /explore-workshop/vibeperform-explore-workshop-hero-1280.webp 1280w"
								sizes="(min-width: 1024px) 42vw, calc(100vw - 2.5rem)"
							/>
							<img
								src={workshopImage}
								alt={content.heroAlt}
								class="aspect-[16/10] w-full object-cover"
								loading="eager"
								fetchpriority="high"
								decoding="async"
								width="1280"
								height="816"
							/>
						</picture>
					</AiImageFrame>
				</figure>
			</div>
		</section>

		<section class="section-spacing bg-[#eeebf4] dark:bg-[#18131e]">
			<div class="container-responsive">
				<div class="max-w-4xl" data-page-reveal>
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">{content.introTitle}</h2>
					<p class="mt-6 max-w-[67ch] text-base leading-7 text-slate-700 dark:text-slate-300 sm:text-lg sm:leading-8">{content.intro}</p>
					<p class="mt-4 max-w-[67ch] text-base leading-7 text-slate-600 dark:text-slate-400 sm:text-lg sm:leading-8">{content.introBody}</p>
				</div>

				<div class="mt-12 grid border-y border-[#c8b4d8] dark:border-[#4a3659] md:grid-cols-3">
					{content.proofItems.map((item) => (
						<div class="py-7 md:border-l md:border-[#c8b4d8] md:px-7 md:first:border-l-0 dark:md:border-[#4a3659]" data-page-reveal>
							<strong class="block text-[clamp(2.35rem,4.5vw,3.65rem)] font-semibold leading-none tracking-[-0.04em] text-purple-800 dark:text-purple-300">{item.stat}</strong>
							<span class="mt-4 block max-w-[30ch] text-sm leading-6 text-slate-600 dark:text-slate-300">{item.copy}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="section-spacing bg-white dark:bg-slate-950">
			<div class="container-responsive grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16">
				<div class="max-w-2xl" data-page-reveal>
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">{content.experienceTitle}</h2>
					<div class="mt-6 space-y-5 text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg sm:leading-8">
						{content.experienceBody.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>
				<figure class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 dark:border-slate-800 dark:bg-slate-900" data-page-reveal>
					<AiImageFrame label={photoDisclosure}>
						<picture>
							<source
								type="image/webp"
								srcset="/explore-workshop/strategic-discovery-workshop-720.webp 720w, /explore-workshop/strategic-discovery-workshop-1280.webp 1280w"
								sizes="(min-width: 1024px) 52vw, calc(100vw - 2.5rem)"
							/>
							<img
								src={experienceImage}
								alt={content.experienceAlt}
								class="aspect-[16/10] w-full object-cover"
								loading="lazy"
								decoding="async"
								width="1280"
								height="720"
							/>
						</picture>
					</AiImageFrame>
				</figure>
			</div>
		</section>

		<section class="section-spacing bg-[#2a1838] text-purple-50">
			<div class="container-responsive">
				<div class="max-w-3xl" data-page-reveal>
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-[#fffafc] sm:text-4xl lg:text-5xl">{content.frameworkTitle}</h2>
					<p class="mt-5 max-w-[62ch] text-base leading-7 text-[#d9cae6] sm:text-lg sm:leading-8">{content.frameworkBody}</p>
				</div>

				<div class="mt-12 grid gap-x-10 gap-y-0 md:grid-cols-2 lg:grid-cols-3">
					{content.frameworkSteps.map((step, index) => (
						<article
							class:list={[
								'border-t border-[#76578a] py-7',
								index === content.frameworkSteps.length - 1 ? 'lg:col-span-2' : '',
							]}
							data-page-reveal
						>
							<span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[#4b2e5c] text-purple-100" aria-hidden="true">
								<span set:html={renderIcon(frameworkIcons[index] ?? Target)} />
							</span>
							<h3 class="mt-5 text-xl font-semibold text-[#fffafc]">{step.title}</h3>
							<p class="mt-3 max-w-[42ch] text-sm leading-6 text-[#cdbbda] sm:text-base sm:leading-7">{step.copy}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section-spacing bg-[#eeebf4] dark:bg-[#18131e]">
			<div class="container-responsive grid overflow-hidden rounded-2xl border border-[#c8b4d8] bg-white dark:border-[#4a3659] dark:bg-[#241b2c] lg:grid-cols-[1.05fr_0.95fr]" data-page-reveal>
				<AiImageFrame label={illustrationDisclosure} class="h-full" mediaClass="h-full">
					<picture class="block h-full">
						<source
							type="image/webp"
							srcset="/explore-workshop/vibeperform-explore-roadmap-720.webp 720w, /explore-workshop/vibeperform-explore-roadmap-1280.webp 1280w"
							sizes="(min-width: 1024px) 52vw, calc(100vw - 2.5rem)"
						/>
						<img
							src={roadmapImage}
							alt={content.roadmapAlt}
							class="h-full min-h-[22rem] w-full object-cover lg:min-h-[34rem]"
							loading="lazy"
							decoding="async"
							width="1280"
							height="816"
						/>
					</picture>
				</AiImageFrame>
				<div class="p-7 sm:p-10 lg:p-12">
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl">{content.priorityTitle}</h2>
					<p class="mt-5 text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg sm:leading-8">{content.priorityBody}</p>
					<div class="mt-8 border-t border-slate-200 dark:border-slate-700" aria-label={content.useCasesLabel}>
						{content.useCases.map((useCase) => (
							<div class="flex items-center gap-4 border-b border-slate-200 py-4 last:border-b-0 dark:border-slate-700">
								<span class="inline-flex h-8 w-8 flex-none items-center justify-center rounded-2xl bg-[#ded2e8] text-purple-800 dark:bg-[#352442] dark:text-purple-200" aria-hidden="true">
									<span set:html={renderIcon(CheckCircle2, 'h-4 w-4')} />
								</span>
								<span class="text-base text-slate-700 dark:text-slate-300">{useCase}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<section id={content.outcomeId} class="section-spacing bg-white dark:bg-slate-950">
			<div class="container-responsive">
				<div class="max-w-3xl" data-page-reveal>
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">{content.outcomeTitle}</h2>
					<p class="mt-5 text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg sm:leading-8">{content.outcomeBody}</p>
				</div>

				<div class="mt-12 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
					{content.deliverables[0] ? (
						<article class="rounded-2xl bg-[#eeebf4] p-7 dark:bg-[#18131e] sm:p-9" data-page-reveal>
							<span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#ded2e8] text-purple-800 dark:bg-[#352442] dark:text-purple-200" aria-hidden="true">
								<span set:html={renderIcon(deliverableIcons[0] ?? Route)} />
							</span>
							<h3 class="mt-6 text-2xl font-semibold tracking-[-0.025em] text-slate-950 dark:text-slate-50">{content.deliverables[0].title}</h3>
							<p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">{content.deliverables[0].copy}</p>
						</article>
					) : null}
					<div>
						{content.deliverables.slice(1).map((item, index) => (
							<article class="border-t border-slate-300 py-7 first:pt-0 dark:border-slate-700" data-page-reveal>
								<span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-purple-100 text-purple-700 dark:bg-purple-950 dark:text-purple-300" aria-hidden="true">
									<span set:html={renderIcon(deliverableIcons[index + 1] ?? Route)} />
								</span>
								<h3 class="mt-5 text-xl font-semibold text-slate-950 dark:text-slate-50 sm:text-2xl">{item.title}</h3>
								<p class="mt-3 max-w-[54ch] text-base leading-7 text-slate-600 dark:text-slate-300">{item.copy}</p>
							</article>
						))}
					</div>
				</div>

				<div class="mt-16 grid items-center gap-8 rounded-2xl bg-[#eeebf4] p-7 dark:bg-[#18131e] sm:p-10 lg:grid-cols-[1fr_auto] lg:p-12" data-page-reveal>
					<div class="max-w-3xl">
						<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl">{content.finalTitle}</h2>
						<p class="mt-4 max-w-[62ch] text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg">{content.finalBody}</p>
					</div>
					<a
						class="inline-flex min-h-12 w-full items-center justify-center whitespace-nowrap rounded-full bg-purple-700 px-6 py-3 text-sm font-semibold text-white shadow-[0_10px_28px_rgba(88,28,135,0.18)] transition hover:bg-purple-800 active:scale-[0.98] dark:bg-purple-500 dark:text-slate-950 dark:hover:bg-purple-400 sm:w-auto"
						href={mailHref}
					>
						{content.finalCta}
					</a>
				</div>
			</div>
		</section>
	</main>

	<Footer currentLocale={locale} />
	<PageReveals />
</div>

<style>
	.explore-main {
		padding-inline: 0;
	}
</style>
