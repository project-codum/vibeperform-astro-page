---
import Button from './Button.astro';
import Footer from './Footer.astro';
import NavBar from './NavBar.astro';
import PageReveals from './PageReveals.astro';
import { ArrowUpRight, Lightbulb, Rocket, UserRoundCog } from 'lucide-static';
import type { WorkshopsContent } from '../data/workshopsContent';

interface Props {
	content: WorkshopsContent;
	homeHref: string;
	alternateLocaleHref: string;
	currentLocale: 'en' | 'de';
}

const { content, homeHref, alternateLocaleHref, currentLocale } = Astro.props as Props;
const { nav, hero, valueSection, scorecard, finalCta } = content;
const locale = currentLocale === 'de' ? 'de' : 'en';
const [heroScenario] = scorecard.scenarios;
const heroCards = [
	{
		title: 'Explore Workshop',
		href: locale === 'de' ? '/de/workshop/explore-workshop/' : '/en/workshop/explore-workshop/',
		ctaLabel: locale === 'de' ? 'Explore Workshop ansehen' : 'View Explore Workshop',
		image: '/workshop2.webp',
		imageAlt:
			locale === 'de'
				? 'Workshop-Ort am See für den Vibeperform Explore Workshop'
				: 'Lakeside workshop venue for the Vibeperform Explore Workshop',
		description:
			locale === 'de'
				? "Wir identifizieren gemeinsam, wo in euren Arbeitsabläufen Potenzial für KI steckt. Dem Explore Workshop folgt der Design Workshop."
				: 'Together we surface where your workflows have the most AI potential. The Design Workshop follows the Explore session.',
		focus: heroScenario.scoreFocus,
		results:
			locale === 'de'
				? [
						'Übersicht über eure größten Pain Points',
						'Shortlist an KI- und Automationsideen',
						'Empfehlung: Womit starten und warum',
					]
				: ['Map of current bottlenecks', 'Shortlist of AI and automation ideas', 'Recommendation on where to start and why'],
	},
	{
		title: 'Design Workshop',
		image: '/workshop3.webp',
		imageAlt:
			locale === 'de'
				? 'Heller Workshop-Raum mit Whiteboard und Vibeperform Bildschirm'
				: 'Bright workshop room with a whiteboard and Vibeperform screen',
		description:
			locale === 'de'
				? 'Wir entwickeln ein Lösungsszenario mit KI für den priorisierten Use Case. Dieser Workshop baut auf dem Explore Workshop auf.'
				: 'We design an AI-enabled solution scenario for the prioritised use case. This session builds on the Explore Workshop.',
		focus:
			locale === 'de'
				? ['Was brauchen die Nutzer der Lösung?', 'Wie sieht der neue Ablauf aus?', 'Wie wird Erfolg gemessen?']
				: ['Who uses the solution?', 'What does the new workflow look like?', 'How do we measure success?'],
		results:
			locale === 'de'
				? [
						'Zukünftiger Prozess mit KI-Unterstützung',
						'Feature-Set und Datenbedarf',
						'Vertrauens- und Qualitätskriterien fürs Team',
					]
				: [
						'Future-state workflow with AI in the loop',
						'Defined feature set and data requirements',
						'Trust and quality criteria for the team',
					],
	},
];

const valueIcons = {
	lightbulb: Lightbulb,
	'user-round-cog': UserRoundCog,
	rocket: Rocket,
} as const;

const renderIcon = (iconSvg: string, className = 'h-6 w-6') =>
	iconSvg
		.replace('class="lucide', `class="lucide ${className}`)
		.replace('width="24"', 'width="24"')
		.replace('height="24"', 'height="24"');

const arrowUpRightIcon = renderIcon(ArrowUpRight, 'h-4 w-4');
---

<div class="flex min-h-screen flex-col bg-white text-slate-950 dark:bg-slate-950 dark:text-slate-100">
	<NavBar nav={nav} homeHref={homeHref} alternateLocaleHref={alternateLocaleHref} currentLocale={locale} />

	<main class="workshops-main flex flex-1 flex-col overflow-hidden">
		<section class="flex min-h-[calc(100dvh-76px)] items-center py-16 lg:py-20">
			<div class="container-responsive grid items-center gap-12 lg:grid-cols-12 lg:gap-12">
				<div class="max-w-3xl lg:col-span-7">
					<p class="text-xs font-semibold uppercase tracking-[0.28em] text-purple-700 dark:text-purple-300 sm:text-sm">
						{hero.kicker}
					</p>
					<h1 class="mt-5 max-w-[18ch] text-[clamp(2.75rem,4.6vw,3.9rem)] font-semibold leading-[1.02] tracking-[-0.055em] text-slate-950 dark:text-slate-50">
						{hero.title}
					</h1>
					<p class="mt-6 max-w-[52ch] text-lg leading-8 text-slate-600 dark:text-slate-300 sm:text-xl">
						{hero.intro}
					</p>
					{hero.cta ? (
						<div class="mt-8 flex flex-col gap-3 sm:flex-row">
							<Button href={hero.cta.href}>{hero.cta.label}</Button>
						</div>
					) : null}
				</div>

				<figure class="relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-[0_24px_70px_rgba(42,24,56,0.14)] dark:border-slate-800 dark:bg-slate-900 lg:col-span-5">
					<img
						src="/workshop1.webp"
						alt={locale === 'de' ? 'Team bei einem moderierten Workshop mit Haftnotizen' : 'Team in a facilitated workshop using sticky notes'}
						class="aspect-[4/3] w-full object-cover"
						loading="eager"
						fetchpriority="high"
						decoding="sync"
						width="650"
						height="433"
					/>
				</figure>
			</div>
		</section>

		{heroScenario ? (
			<section class="section-spacing bg-[#eeebf4] dark:bg-[#18131e]">
				<div class="container-responsive">
					<div class="max-w-3xl" data-page-reveal>
						<p class="text-xs font-semibold uppercase tracking-[0.28em] text-purple-700 dark:text-purple-300">
							{locale === 'de' ? 'Formate im Überblick' : 'Formats at a glance'}
						</p>
						<h2 class="mt-4 text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl lg:text-5xl">
							{locale === 'de' ? 'Wo wir gemeinsam einsteigen' : 'Where we start together'}
						</h2>
						<p class="mt-5 max-w-[62ch] text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg sm:leading-8">
							{locale === 'de'
								? 'Wir arbeiten vor Ort in und um München. Nach dem Explore Workshop verdichten wir den wichtigsten Use Case im Design Workshop zu einem belastbaren Lösungsbild.'
								: 'We work on-site in and around Munich. After the Explore Workshop, we turn the strongest use case into a robust solution concept in the Design Workshop.'}
						</p>
					</div>

					<div class="mt-12 grid gap-6 lg:grid-cols-2">
						{heroCards.map((card) => (
							<article class="group relative overflow-hidden rounded-2xl border border-[#c8b4d8] bg-white transition duration-300 hover:-translate-y-1 hover:shadow-[0_22px_50px_rgba(42,24,56,0.12)] dark:border-[#4a3659] dark:bg-[#241b2c]" data-page-reveal>
								{card.href ? (
									<a class="absolute inset-0 z-10" href={card.href} aria-label={card.ctaLabel}>
										<span class="sr-only">{card.ctaLabel}</span>
									</a>
								) : null}
								<div class="overflow-hidden bg-slate-100 dark:bg-slate-900">
									<img
										src={card.image}
										alt={card.imageAlt}
										class="aspect-[16/9] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
										loading="lazy"
										decoding="async"
									/>
								</div>
								<div class="p-6 sm:p-8">
									<div class="flex items-start justify-between gap-5">
										<h3 class="text-2xl font-semibold tracking-[-0.025em] text-slate-950 dark:text-slate-50 sm:text-3xl">{card.title}</h3>
										{card.href ? <span class="mt-1 text-purple-700 dark:text-purple-300" aria-hidden="true" set:html={arrowUpRightIcon} /> : null}
									</div>
									<p class="mt-4 max-w-[52ch] text-sm leading-6 text-slate-600 dark:text-slate-300 sm:text-base sm:leading-7">{card.description}</p>
									<div class="mt-7 border-t border-slate-200 dark:border-slate-700">
										{card.focus.map((focus) => (
											<p class="border-b border-slate-200 py-3 text-sm text-slate-700 last:border-b-0 dark:border-slate-700 dark:text-slate-300">{focus}</p>
										))}
									</div>
									<div class="mt-6 rounded-2xl bg-[#ded2e8] p-5 dark:bg-[#352442]">
										<p class="text-sm font-semibold text-[#3c234d] dark:text-purple-100">{locale === 'de' ? 'Das nehmt ihr mit' : 'What you leave with'}</p>
										<ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700 dark:text-slate-300">
											{card.results.map((line) => <li>{line}</li>)}
										</ul>
									</div>
									{card.href ? <p class="mt-6 text-sm font-semibold text-purple-800 dark:text-purple-300">{card.ctaLabel}</p> : null}
								</div>
							</article>
						))}
					</div>
				</div>
			</section>
		) : null}

		<section class="section-spacing bg-[#2a1838] text-purple-50">
			<div class="container-responsive">
				<div class="max-w-3xl" data-page-reveal>
					<h2 class="text-3xl font-semibold tracking-[-0.035em] text-[#fffafc] sm:text-4xl lg:text-5xl">{valueSection.heading}</h2>
					<p class="mt-5 max-w-[58ch] text-base leading-7 text-[#d9cae6] sm:text-lg sm:leading-8">
						{locale === 'de'
							? 'Wir verbinden Prozessverständnis, technische Umsetzung und die Menschen, die später mit der Lösung arbeiten.'
							: 'We connect process insight, technical delivery, and the people who will work with the solution every day.'}
					</p>
				</div>

				<div class="mt-12 grid gap-5 lg:grid-cols-12">
					{valueSection.bullets.map((item, index) => {
						const iconSvg = item.icon && item.icon in valueIcons ? valueIcons[item.icon as keyof typeof valueIcons] : Lightbulb;
						return (
							<article
								class:list={[
									'group',
									index === 0
										? 'rounded-2xl bg-[#3a2348] p-7 sm:p-9 lg:col-span-5 lg:row-span-2'
										: 'border-t border-[#76578a] py-7 lg:col-span-7 lg:px-4',
								]}
								data-page-reveal
							>
								<span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[#5b3970] text-purple-100" aria-hidden="true">
									<span set:html={renderIcon(iconSvg)} />
								</span>
								<h3 class="mt-6 text-xl font-semibold text-[#fffafc] sm:text-2xl">{item.title}</h3>
								<p class="mt-3 max-w-[52ch] text-sm leading-6 text-[#cdbbda] sm:text-base sm:leading-7">{item.body}</p>
							</article>
						);
					})}
				</div>
			</div>
		</section>

		<section class="section-spacing bg-white dark:bg-slate-950">
			<div class="container-responsive" data-page-reveal>
				<div class="grid items-center gap-8 rounded-2xl bg-[#eeebf4] p-7 dark:bg-[#18131e] sm:p-10 lg:grid-cols-[1fr_auto] lg:p-12">
					<div class="max-w-2xl">
						<h2 class="text-3xl font-semibold tracking-[-0.035em] text-slate-950 dark:text-slate-50 sm:text-4xl">{finalCta.heading}</h2>
						<p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300 sm:text-lg">{finalCta.body}</p>
					</div>
					<div class="lg:justify-self-end">
						<Button href={finalCta.button.href}>{finalCta.button.label}</Button>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer currentLocale={locale} />
	<PageReveals />
</div>

<style>
	.workshops-main {
		padding-inline: 0;
	}
</style>
