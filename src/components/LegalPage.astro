---
import Footer from './Footer.astro';
import NavBar from './NavBar.astro';
import type { LegalContent } from '../data/legalContent';

interface Props {
	content: LegalContent;
	homeHref: string;
	alternateLocaleHref: string;
	currentLocale: 'de' | 'en';
}

const { content, homeHref, alternateLocaleHref, currentLocale } = Astro.props as Props;
---

<div class="flex min-h-screen flex-col bg-white">
	<NavBar nav={content.nav} homeHref={homeHref} alternateLocaleHref={alternateLocaleHref} currentLocale={currentLocale} />

	<main class="flex flex-1 flex-col pb-20">
		<section class="section-spacing">
			<div class="container-responsive mx-auto max-w-4xl space-y-6">
				<p class="text-xs font-semibold uppercase tracking-[0.35em] text-slate-500 sm:text-sm">{content.kicker}</p>
				<h1 class="text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">{content.title}</h1>
				<div class="legal-rich-text space-y-4 text-base text-slate-600 sm:text-lg">
					{content.intro.map((paragraph) => (
						<p set:html={paragraph} />
					))}
				</div>
				<p class="text-sm font-medium text-slate-500">{content.updatedLabel}: {content.updated}</p>
			</div>
		</section>

		{content.noticeItems.length > 0 ? (
			<section class="bg-slate-50 py-10">
				<div class="container-responsive mx-auto max-w-4xl">
					<div class="rounded-2xl border border-amber-200 bg-amber-50 p-6 text-amber-950">
						<h2 class="text-lg font-semibold">{content.noticeTitle}</h2>
						<ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-6">
							{content.noticeItems.map((item) => (
								<li set:html={item} />
							))}
						</ul>
					</div>
				</div>
			</section>
		) : null}

		<section class="section-spacing">
			<div class="container-responsive mx-auto max-w-4xl space-y-10">
				{content.sections.map((section) => (
					<section class="border-t border-slate-200 pt-8">
						<h2 class="text-2xl font-semibold text-slate-900">{section.title}</h2>
						<div class="legal-rich-text mt-4 space-y-4 text-base leading-7 text-slate-600">
							{section.paragraphs.map((paragraph) => (
								<p set:html={paragraph} />
							))}
						</div>
					</section>
				))}
			</div>
		</section>
	</main>

	<Footer currentLocale={currentLocale} />
</div>

<style>
	.legal-rich-text :global(a) {
		color: rgb(126 34 206);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.legal-rich-text :global(a:hover) {
		color: rgb(88 28 135);
	}

	.legal-rich-text :global(code) {
		border-radius: 0.375rem;
		background: rgb(241 245 249);
		color: rgb(51 65 85);
		font-size: 0.92em;
		padding: 0.1rem 0.3rem;
	}
</style>
