---
import ConsentManagerHead from '../components/ConsentManagerHead.astro';
import '../styles/global.css';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import { homeContent } from '../data/homeContent';
import Button from '../components/Button.astro';
import { absoluteUrl, blogPostingSchema, jsonLd } from '../lib/siteMetadata';

const { frontmatter } = Astro.props;
const {
	title,
	seoTitle,
	kicker,
	date,
	lastModified = date,
	author,
	authorRole,
	authorHref,
	readTime,
	coverImage,
	coverImageFallback,
	coverImageAlt,
	coverImageWidth,
	coverImageHeight,
	excerpt,
	lang,
	alternateLocaleHref,
	ctaTitle: customCtaTitle,
	ctaBody: customCtaBody,
	ctaButtonText: customCtaButtonText,
	ctaHref: customCtaHref,
} = frontmatter;

const locale = lang === 'de' ? 'de' : 'en';
const nav = homeContent[locale].nav;
const homeHref = locale === 'de' ? '/de/' : '/en/';
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;

const formattedDate = new Date(date).toLocaleDateString(
	locale === 'de' ? 'de-DE' : 'en-US',
	{ year: 'numeric', month: 'long', day: 'numeric' }
);
const formattedLastModified = new Date(lastModified).toLocaleDateString(
	locale === 'de' ? 'de-DE' : 'en-US',
	{ year: 'numeric', month: 'long', day: 'numeric' }
);

const backText = locale === 'de' ? 'Zurück zum Blog' : 'Back to Blog';
const backHref = locale === 'de' ? '/de/blog/' : '/en/blog/';

const defaultCtaTitle = locale === 'de'
	? 'Bereit für den nächsten Schritt?'
	: 'Ready to take the next step?';
const defaultCtaBody = locale === 'de'
	? 'Lass uns in einem unverbindlichen Erstgespräch herausfinden, wo in deinen Unternehmensprozessen die größten Potenziale für KI-Agenten liegen.'
	: 'Let’s find out where the biggest potentials for AI agents lie in your business processes during a free, no-obligation discovery call.';
const defaultCtaButtonText = locale === 'de'
	? 'Erstgespräch vereinbaren'
	: 'Book a discovery call';
const ctaTitle = customCtaTitle ?? defaultCtaTitle;
const ctaBody = customCtaBody ?? defaultCtaBody;
const ctaButtonText = customCtaButtonText ?? defaultCtaButtonText;
const ctaHref = customCtaHref ?? 'https://calendar.app.google/utFQgw33PwJTiDk56';
const ctaIsExternal = /^https?:\/\//.test(ctaHref);
const normalizedPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const normalizedAlternatePath = alternateLocaleHref.replace(/\/+$/, '') || '/';
const canonicalUrl = absoluteUrl(normalizedPath);
const alternateUrl = absoluteUrl(normalizedAlternatePath);
const socialImagePath = coverImageFallback ?? coverImage;
const socialImageUrl = socialImagePath ? absoluteUrl(socialImagePath) : undefined;
const structuredData = blogPostingSchema({
	title,
	description: excerpt,
	pathname: normalizedPath,
	image: socialImagePath,
	datePublished: date,
	dateModified: lastModified,
	author,
	authorRole,
	authorUrl: authorHref ? absoluteUrl(authorHref) : undefined,
	locale,
});
---

<html lang={locale}>
	<head>
		<ConsentManagerHead locale={locale} />
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			window.gtag = window.gtag || function(){window.dataLayer.push(arguments);};

			(() => {
				const measurementId = 'G-FQ744XXNZ7';
				const tagSrc = 'https://www.googletagmanager.com/gtag/js?id=' + measurementId;

				const loadGoogleTag = () => {
					if (window.__vibeperformGoogleTagLoaded) return;
					window.__vibeperformGoogleTagLoaded = true;

					const script = document.createElement('script');
					script.async = true;
					script.src = tagSrc;
					script.onload = () => {
						window.gtag('js', new Date());
						window.gtag('config', measurementId);
					};
					document.head.appendChild(script);
				};

				const hasAcceptedAllConsent = (cmpData) => {
					const groups = [cmpData?.purposeConsents, cmpData?.vendorConsents].filter(Boolean);
					return groups.length > 0 && groups.every((group) => Object.values(group).length > 0 && Object.values(group).every(Boolean));
				};

				const loadIfStoredConsentAllows = () => {
					try {
						const cmpData = window.__cmp?.('getCMPData');
						if (hasAcceptedAllConsent(cmpData)) loadGoogleTag();
					} catch (_error) {
						// Keep analytics disabled if CMP data is unavailable.
					}
				};

				const handleCmpEvent = (eventName) => {
					if (eventName === 'consentapproved') {
						loadGoogleTag();
						return;
					}
					if (eventName === 'consent' || eventName === 'loadNotShowing') loadIfStoredConsentAllows();
				};

				if (typeof window.__cmp === 'function') {
					window.__cmp('addEventListener', ['consentapproved', handleCmpEvent, false], null);
					window.__cmp('addEventListener', ['consent', handleCmpEvent, false], null);
					window.__cmp('addEventListener', ['loadNotShowing', handleCmpEvent, false], null);
					loadIfStoredConsentAllows();
				}
			})();
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<meta name="generator" content={Astro.generator} />
		<title>{seoTitle ?? `${title} | Vibeperform`}</title>
		{excerpt ? <meta name="description" content={excerpt} /> : null}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang={locale} href={canonicalUrl} />
		<link rel="alternate" hreflang={locale === 'de' ? 'en' : 'de'} href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={locale === 'de' ? canonicalUrl : alternateUrl} />
		<meta property="og:type" content="article" />
		<meta property="og:site_name" content="Vibeperform" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={excerpt} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
		<meta property="og:locale:alternate" content={locale === 'de' ? 'en_US' : 'de_DE'} />
		{socialImageUrl ? <meta property="og:image" content={socialImageUrl} /> : null}
		{coverImageAlt ? <meta property="og:image:alt" content={coverImageAlt} /> : null}
		<meta property="article:published_time" content={date} />
		<meta property="article:modified_time" content={lastModified} />
		<meta property="article:author" content={author} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={excerpt} />
		{socialImageUrl ? <meta name="twitter:image" content={socialImageUrl} /> : null}
		{coverImageAlt ? <meta name="twitter:image:alt" content={coverImageAlt} /> : null}
		<script type="application/ld+json" set:html={jsonLd(structuredData)} />
	</head>

	<body class="bg-white text-slate-900 antialiased">
		<div class="flex min-h-screen flex-col bg-white">
			<NavBar nav={nav} homeHref={homeHref} alternateLocaleHref={alternateLocaleHref} currentLocale={locale} />

			<main class="flex flex-1 flex-col pb-24">
				{/* Article Wrapper */}
				<article class="container-responsive mx-auto max-w-3xl pt-8">
					
					{/* Back Navigation */}
					<a
						href={backHref}
						class="group mb-8 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 hover:text-slate-900 transition-colors"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-4 w-4 transform transition-transform group-hover:-translate-x-1"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10 19l-7-7m0 0l7-7m-7 7h18"
							/>
						</svg>
						{backText}
					</a>

					{/* Header Content */}
					<header class="space-y-4 text-left">
						<p class="text-xs font-bold uppercase tracking-[0.3em] text-purple-600 sm:text-sm">
							{kicker}
						</p>
						<h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl md:text-5xl md:leading-tight [text-wrap:balance]">
							{title}
						</h1>

						{/* Author & Date metadata */}
						<div class="flex items-center gap-4 pt-2 text-xs text-slate-500 sm:text-sm">
							<div class="flex h-8 w-8 items-center justify-center rounded-full bg-purple-100 text-xs font-semibold text-purple-700">
								{author.split(' ').map((n: string) => n[0]).join('')}
							</div>
							<div class="space-y-1">
								<p class="font-medium text-slate-900">
									{authorHref ? <a class="hover:text-purple-700 hover:underline" href={authorHref}>{author}</a> : author}
								</p>
								{authorRole ? <p class="text-slate-600">{authorRole}</p> : null}
								<p class="flex flex-wrap items-center gap-2">
									<time datetime={date}>{formattedDate}</time>
									<span class="inline-block h-1 w-1 rounded-full bg-slate-300" />
									<span>{readTime}</span>
									{lastModified !== date ? (
										<>
											<span class="inline-block h-1 w-1 rounded-full bg-slate-300" />
											<span>{locale === 'de' ? 'Aktualisiert' : 'Updated'} <time datetime={lastModified}>{formattedLastModified}</time></span>
										</>
									) : null}
								</p>
							</div>
						</div>
					</header>

					{/* Hero Image */}
					{coverImage && (
						<div class="mt-8 mb-12 overflow-hidden rounded-3xl border border-slate-200 shadow-md">
							<picture>
								{coverImageFallback && coverImage.endsWith('.avif') ? <source srcset={coverImage} type="image/avif" /> : null}
								<img
									src={coverImageFallback ?? coverImage}
									alt={coverImageAlt ?? title}
									width={coverImageWidth}
									height={coverImageHeight}
									class="w-full aspect-[2/1] object-cover transition-transform duration-700 hover:scale-102"
									loading="eager"
									fetchpriority="high"
									decoding="async"
								/>
							</picture>
						</div>
					)}

					{/* Content Section */}
					<div class="blog-content">
						<slot />
					</div>

					{/* In-Article Call To Action */}
					<div class="mt-16 rounded-3xl border border-slate-200 bg-slate-50 p-8 shadow-sm text-left sm:p-10 transition hover:shadow-md">
					<h2 class="text-xl font-bold text-slate-900 sm:text-2xl">{ctaTitle}</h2>
					<p class="mt-3 text-base leading-relaxed text-slate-600">{ctaBody}</p>
					<div class="mt-6">
						<Button href={ctaHref} target={ctaIsExternal ? '_blank' : undefined} rel={ctaIsExternal ? 'noreferrer noopener' : undefined}>
							{ctaButtonText}
						</Button>
						</div>
					</div>
				</article>
			</main>

			<Footer currentLocale={locale} />
		</div>
	</body>
</html>

<style>
	/* Scoped markdown styles for ultimate typography and readability */
	.blog-content {
		color: var(--color-slate-700);
	}
	.blog-content :global(p) {
		font-size: 1.0625rem; /* ~17px */
		line-height: 1.75;
		margin-bottom: 1.5rem;
		text-wrap: pretty;
	}
	@media (min-width: 640px) {
		.blog-content :global(p) {
			font-size: 1.125rem; /* 18px */
		}
	}
	.blog-content :global(h2) {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--color-slate-900);
		margin-top: 3.5rem;
		margin-bottom: 1.25rem;
		letter-spacing: -0.03em;
		text-wrap: balance;
	}
	@media (min-width: 640px) {
		.blog-content :global(h2) {
			font-size: 2rem;
		}
	}
	.blog-content :global(h3) {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--color-slate-900);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		letter-spacing: -0.025em;
		text-wrap: balance;
	}
	@media (min-width: 640px) {
		.blog-content :global(h3) {
			font-size: 1.75rem;
		}
	}
	.blog-content :global(h4) {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-slate-900);
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		text-wrap: balance;
	}
	.blog-content :global(ul) {
		list-style-type: disc;
		padding-left: 1.5rem;
		margin-bottom: 1.5rem;
	}
	.blog-content :global(ol) {
		list-style-type: decimal;
		padding-left: 1.5rem;
		margin-bottom: 1.5rem;
	}
	.blog-content :global(li) {
		margin-bottom: 0.5rem;
		line-height: 1.625;
		text-wrap: pretty;
	}
	.blog-content :global(figure) {
		margin-top: 2.5rem;
		margin-bottom: 2.5rem;
	}
	.blog-content :global(figure img) {
		display: block;
		width: 100%;
		border-radius: 1.5rem;
		border: 1px solid var(--color-slate-200);
		box-shadow: 0 18px 45px color-mix(in srgb, var(--color-slate-900) 12%, transparent);
	}
	.blog-content :global(figcaption) {
		margin-top: 0.75rem;
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--color-slate-500);
		text-align: center;
	}
	.blog-content :global(blockquote) {
		border-left-width: 4px;
		border-left-color: var(--color-purple-500);
		background-color: color-mix(in srgb, var(--color-purple-50) 40%, transparent);
		padding: 1.25rem 1.5rem;
		border-top-right-radius: 1.5rem;
		border-bottom-right-radius: 1.5rem;
		font-style: italic;
		color: var(--color-slate-800);
		margin-top: 2rem;
		margin-bottom: 2rem;
	}
	.blog-content :global(blockquote p) {
		margin-bottom: 0;
	}
	.blog-content :global(hr) {
		border-top-width: 1px;
		border-top-color: var(--color-slate-200);
		margin-top: 2.5rem;
		margin-bottom: 2.5rem;
	}
	.blog-content :global(strong) {
		font-weight: 600;
		color: var(--color-slate-900);
	}
	.blog-content :global(a) {
		color: var(--color-purple-700);
		font-weight: 600;
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--color-purple-500) 45%, transparent);
		text-underline-offset: 0.2em;
	}
	.blog-content :global(a:hover) {
		color: var(--color-purple-900);
		text-decoration-color: currentColor;
	}
</style>
