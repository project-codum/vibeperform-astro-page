---
import ConsentManagerHead from '../components/ConsentManagerHead.astro';
import '../styles/global.css';
const { content } = Astro.props;
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
---

<html lang="en">
	<head>
		<ConsentManagerHead locale="en" />
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			window.gtag = window.gtag || function(){window.dataLayer.push(arguments);};

			(() => {
				const measurementId = 'G-FQ744XXNZ7';
				const tagSrc = 'https://www.googletagmanager.com/gtag/js?id=' + measurementId;

				const loadGoogleTag = () => {
					if (window.__vibeperformGoogleTagLoaded) return;
					window.__vibeperformGoogleTagLoaded = true;

					const script = document.createElement('script');
					script.async = true;
					script.src = tagSrc;
					script.onload = () => {
						window.gtag('js', new Date());
						window.gtag('config', measurementId);
					};
					document.head.appendChild(script);
				};

				const hasAcceptedAllConsent = (cmpData) => {
					const groups = [cmpData?.purposeConsents, cmpData?.vendorConsents].filter(Boolean);
					return groups.length > 0 && groups.every((group) => Object.values(group).length > 0 && Object.values(group).every(Boolean));
				};

				const loadIfStoredConsentAllows = () => {
					try {
						const cmpData = window.__cmp?.('getCMPData');
						if (hasAcceptedAllConsent(cmpData)) loadGoogleTag();
					} catch (_error) {
						// Keep analytics disabled if CMP data is unavailable.
					}
				};

				const handleCmpEvent = (eventName) => {
					if (eventName === 'consentapproved') {
						loadGoogleTag();
						return;
					}
					if (eventName === 'consent' || eventName === 'loadNotShowing') loadIfStoredConsentAllows();
				};

				if (typeof window.__cmp === 'function') {
					window.__cmp('addEventListener', ['consentapproved', handleCmpEvent, false], null);
					window.__cmp('addEventListener', ['consent', handleCmpEvent, false], null);
					window.__cmp('addEventListener', ['loadNotShowing', handleCmpEvent, false], null);
					loadIfStoredConsentAllows();
				}
			})();
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{content.title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
