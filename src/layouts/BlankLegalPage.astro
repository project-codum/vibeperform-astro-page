---
import '../styles/global.css';
import { absoluteUrl } from '../lib/siteMetadata';

type Locale = 'de' | 'en';

interface Props {
	lang: Locale;
	title: string;
	canonicalPath: string;
	alternatePath: string;
	alternateLang: Locale;
	xDefaultPath: string;
}

const { lang, title, canonicalPath, alternatePath, alternateLang, xDefaultPath } = Astro.props as Props;
const faviconHref = `${import.meta.env.BASE_URL}favicon.png`;
const canonicalUrl = absoluteUrl(canonicalPath);
const alternateUrl = absoluteUrl(alternatePath);
const xDefaultUrl = absoluteUrl(xDefaultPath);
---

<html lang={lang}>
	<head>
		<script type="text/javascript" data-cmp-ab="1" src="https://cdn.consentmanager.net/delivery/autoblocking/4c6af0ac92829.js" data-cmp-host="d.delivery.consentmanager.net" data-cmp-cdn="cdn.consentmanager.net" data-cmp-codesrc="16"></script>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-FQ744XXNZ7"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-FQ744XXNZ7');
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<title>{title}</title>
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang={lang} href={canonicalUrl} />
		<link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
	</head>

	<body class="bg-white text-slate-900">
		<main></main>
	</body>
</html>
